<Window x:Class="AFR.UI.FontSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="AFR — 字体替换配置"
        Width="320" Height="400"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="10" Background="{DynamicResource RegionBrush}"
            TextElement.FontFamily="鸿蒙黑体, 微软雅黑, 黑体"
            MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Grid Margin="20,16,20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- 0: 标题 -->
                <RowDefinition Height="20"/>   <!-- 1: 间距 -->
                <RowDefinition Height="Auto"/> <!-- 2: SHX主字体（西文） -->
                <RowDefinition Height="12"/>   <!-- 3: 间距 -->
                <RowDefinition Height="Auto"/> <!-- 4: SHX大字体（中文） -->
                <RowDefinition Height="12"/>   <!-- 5: 间距 -->
                <RowDefinition Height="Auto"/> <!-- 6: TrueType字体（中文） -->
                <RowDefinition Height="*"/>    <!-- 7: 弹性 -->
                <RowDefinition Height="Auto"/> <!-- 8: 按钮 -->
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="AFR 字体替换配置"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Text="选择用于替换缺失字体的默认字体"
                           FontSize="12" Margin="0,4,0,0"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
            </StackPanel>

            <!-- SHX 字体选择 -->
            <Border Grid.Row="2" CornerRadius="6"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="12,8">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="&#xE71B;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>
                        <TextBlock Text="SHX主字体（西文）" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </StackPanel>
                    <ComboBox IsEditable="True" IsTextSearchEnabled="True" Height="30"
                              hc:InfoElement.Placeholder="搜索或选择 SHX 字体..."
                              Style="{StaticResource ComboBoxExtend}"
                              ItemsSource="{Binding AvailableMainFonts}"
                              Text="{Binding SelectedMainFont, UpdateSourceTrigger=PropertyChanged}"
                              Loaded="OnComboBoxLoaded"/>
                </StackPanel>
            </Border>

            <!-- SHX大字体（中文）选择 -->
            <Border Grid.Row="4" CornerRadius="6"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="12,8">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="&#xE8D2;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>
                        <TextBlock Text="SHX大字体（中文）" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </StackPanel>
                    <ComboBox IsEditable="True" IsTextSearchEnabled="True" Height="30"
                              hc:InfoElement.Placeholder="搜索或选择大字体..."
                              Style="{StaticResource ComboBoxExtend}"
                              ItemsSource="{Binding AvailableBigFonts}"
                              Text="{Binding SelectedBigFont, UpdateSourceTrigger=PropertyChanged}"
                              Loaded="OnComboBoxLoaded"/>
                </StackPanel>
            </Border>

            <!-- TrueType字体（中文）选择 -->
            <Border Grid.Row="6" CornerRadius="6"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Padding="12,8">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="&#xE8D4;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                   Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"
                                   Margin="0,0,6,0"/>
                        <TextBlock Text="TrueType字体（中文）" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                    </StackPanel>
                    <ComboBox IsEditable="True" IsTextSearchEnabled="True" Height="30"
                              hc:InfoElement.Placeholder="搜索或选择 TrueType 字体..."
                              Style="{StaticResource ComboBoxExtend}"
                              ItemsSource="{Binding AvailableTrueTypeFonts}"
                              Text="{Binding SelectedTrueTypeFont, UpdateSourceTrigger=PropertyChanged}"
                              Loaded="OnComboBoxLoaded"/>
                </StackPanel>
            </Border>

            <!-- 按钮 -->
            <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消"
                        MinWidth="80" Height="32" FontSize="12"
                        Margin="0,0,10,0"
                        hc:BorderElement.CornerRadius="6"
                        IsCancel="True" Click="OnCancel"/>
                <Button Content="确认"
                        MinWidth="80" Height="32" FontSize="12"
                        Style="{StaticResource ButtonPrimary}"
                        hc:BorderElement.CornerRadius="6"
                        IsEnabled="{Binding IsConfirmEnabled}"
                        IsDefault="True" Click="OnConfirm"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
