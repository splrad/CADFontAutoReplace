<Window x:Class="AFR.UI.FontReplacementLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
		Title="AFR — 字体替换日志"
		Width="610" Height="620"
		WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <SolidColorBrush x:Key="TrueTypeBrush" Color="#7C4DFF"/>
            <SolidColorBrush x:Key="RuntimeMappingBrush" Color="#00897B"/>
        </ResourceDictionary>
    </Window.Resources>

	<Border CornerRadius="10" Background="{DynamicResource RegionBrush}"
			UseLayoutRounding="True"
			TextElement.FontFamily="鸿蒙黑体, 微软雅黑, 黑体"
			MouseLeftButtonDown="Window_MouseLeftButtonDown">
		<Grid Margin="20,14,20,14">
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto"/>  <!-- 0: 标题 -->
				<RowDefinition Height="8"/>     <!-- 1: 间距 -->
				<RowDefinition Height="Auto"/>  <!-- 2: 状态条 -->
				<RowDefinition Height="8"/>     <!-- 3: 间距 -->
				<RowDefinition Height="*"/>     <!-- 4: 样式表+MText（统一滚动） -->
				<RowDefinition Height="8"/>     <!-- 5: 间距 -->
				<RowDefinition Height="Auto"/>  <!-- 6: 按钮 -->
			</Grid.RowDefinitions>

            <!-- 标题 -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="AFR 字体替换日志"
                           FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Text="可手动调整各样式的替换字体（仅对当前图纸生效）"
                           FontSize="11" Margin="0,3,0,0"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
            </StackPanel>

            <!-- 状态条：左侧彩色标签 + 右侧统计 -->
            <Border Grid.Row="2" CornerRadius="5" Padding="10,5"
                    Background="{DynamicResource SecondaryRegionBrush}"
                    Visibility="{Binding HasAnyContent, Converter={StaticResource BoolToVis}}">
                <Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto"/>
						<ColumnDefinition Width="*"/>
					</Grid.ColumnDefinitions>
					<StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
						<!-- 未替换计数（醒目红色，置于最前） -->
						<Border CornerRadius="3" Padding="6,2" Margin="0,0,6,0"
								Background="{DynamicResource DangerBrush}"
								Visibility="{Binding HasFailed, Converter={StaticResource BoolToVis}}">
							<TextBlock Text="{Binding FailedLabel}" FontSize="10" FontWeight="Bold" Foreground="White"/>
						</Border>
						<!-- SHX主字体计数 -->
                        <Border CornerRadius="3" Padding="6,2" Margin="0,0,6,0"
                                Background="{DynamicResource PrimaryBrush}"
                                Visibility="{Binding HasShx, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding ShxLabel}" FontSize="10" Foreground="White"/>
                        </Border>
                        <!-- SHX大字体计数 -->
                        <Border CornerRadius="3" Padding="6,2" Margin="0,0,6,0"
                                Background="{DynamicResource WarningBrush}"
                                Visibility="{Binding HasBigFont, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding BigFontLabel}" FontSize="10" Foreground="White"/>
                        </Border>
                        <!-- TrueType 计数 -->
                        <Border CornerRadius="3" Padding="6,2"
                                Background="{StaticResource TrueTypeBrush}"
                                Visibility="{Binding HasTrueType, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding TrueTypeLabel}" FontSize="10" Foreground="White"/>
                        </Border>
                        <!-- MText内联字体映射计数 -->
                        <Border CornerRadius="3" Padding="6,2" Margin="6,0,0,0"
                                Background="{StaticResource RuntimeMappingBrush}"
                                Visibility="{Binding HasFontMappings, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding FontMappingLabel}" FontSize="10" Foreground="White"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding SummaryText}"
                               Margin="10,0,0,0"
                               FontSize="11" VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>
            </Border>

			<!-- 空状态提示 -->
			<TextBlock Grid.Row="4"
					   Text="当前图纸未检测到缺失字体 ✓"
					   HorizontalAlignment="Center" VerticalAlignment="Center"
					   FontSize="14"
					   Foreground="{DynamicResource SecondaryTextBrush}"
					   Visibility="{Binding HasNoItems, Converter={StaticResource BoolToVis}}"/>

			<!-- ═══ 分层内容区：粘性标题 + 滚动数据 ═══ -->
			<Border Grid.Row="4" CornerRadius="6" ClipToBounds="True"
					BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
					Visibility="{Binding HasAnyContent, Converter={StaticResource BoolToVis}}">
				<Grid>
					<!-- Layer 1: 粘性标题覆盖层 (ZIndex=1，始终置顶) -->
					<Border x:Name="StickyHeaderOverlay" VerticalAlignment="Top" Panel.ZIndex="1"
							Background="{DynamicResource SecondaryRegionBrush}">
						<StackPanel>
							<!-- 样式表标题组 -->
							<StackPanel x:Name="StickyStyleHeader"
										Visibility="{Binding HasItems, Converter={StaticResource BoolToVis}}">
								<Border Padding="8,7,8,7"
										BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
									<TextBlock Text="样式表字体替换"
											   FontSize="11" FontWeight="SemiBold"
											   Foreground="{DynamicResource PrimaryTextBrush}"/>
								</Border>
								<Border Padding="11,5,8,5"
										BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="3*"/>
											<ColumnDefinition Width="100"/>
											<ColumnDefinition Width="2*"/>
											<ColumnDefinition Width="2*"/>
										</Grid.ColumnDefinitions>
										<TextBlock Grid.Column="0" Text="样式名" FontSize="10"
												   Foreground="{DynamicResource SecondaryTextBrush}"
												   VerticalAlignment="Center"/>
										<TextBlock Grid.Column="1" Text="类型" FontSize="10"
												   Foreground="{DynamicResource SecondaryTextBrush}"
												   HorizontalAlignment="Center" VerticalAlignment="Center"/>
										<TextBlock Grid.Column="2" Text="缺失字体" FontSize="10"
												   Foreground="{DynamicResource SecondaryTextBrush}"
												   HorizontalAlignment="Left" VerticalAlignment="Center"/>
										<TextBlock Grid.Column="3" Text="替换字体" FontSize="10"
												   Foreground="{DynamicResource SecondaryTextBrush}"
												   HorizontalAlignment="Center" VerticalAlignment="Center"/>
									</Grid>
								</Border>
							</StackPanel>

							<!-- MText内联字体映射标题组 -->
							<StackPanel x:Name="StickyFontMappingHeader" Visibility="Collapsed">
								<Border Padding="8,7,8,7"
										BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
									<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
										<TextBlock Text="MText内联字体映射"
												   FontSize="11" FontWeight="SemiBold"
												   Foreground="{DynamicResource PrimaryTextBrush}"/>
										<Border CornerRadius="3" Padding="5,1" Margin="8,0,0,0"
												Background="{StaticResource RuntimeMappingBrush}">
											<TextBlock Text="{Binding FontMappingCount}" FontSize="9" Foreground="White"/>
										</Border>
									</StackPanel>
								</Border>
								<Border Padding="11,5,8,5"
										BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="3*"/>
											<ColumnDefinition Width="150"/>
											<ColumnDefinition Width="3*"/>
											<ColumnDefinition Width="84"/>
										</Grid.ColumnDefinitions>
										<TextBlock Grid.Column="0" Text="缺失字体" FontSize="10"
												   Foreground="{DynamicResource SecondaryTextBrush}"
												   HorizontalAlignment="Left" VerticalAlignment="Center"/>
										<TextBlock Grid.Column="1" Text="类型" FontSize="10"
												   Foreground="{DynamicResource SecondaryTextBrush}"
												   HorizontalAlignment="Center" VerticalAlignment="Center"/>
										<TextBlock Grid.Column="2" Text="映射字体" FontSize="10"
												   Foreground="{DynamicResource SecondaryTextBrush}"
												   HorizontalAlignment="Left" VerticalAlignment="Center"/>
										<TextBlock Grid.Column="3" Text="Hook" FontSize="10"
												   Foreground="{DynamicResource SecondaryTextBrush}"
												   HorizontalAlignment="Left" VerticalAlignment="Center"/>
									</Grid>
								</Border>
							</StackPanel>
						</StackPanel>
					</Border>

					<!-- Layer 0: 可滚动内容 -->
					<ScrollViewer x:Name="ContentScroll" VerticalScrollBarVisibility="Auto"
								  PreviewMouseWheel="OnTablePreviewMouseWheel"
								  ScrollChanged="OnScrollChanged" Loaded="OnTableLoaded">
						<StackPanel>

							<!-- ─── 样式表区块 ─── -->
							<StackPanel x:Name="StyleSection"
										Visibility="{Binding HasItems, Converter={StaticResource BoolToVis}}">
								<!-- 占位：与粘性样式表标题同高（被覆盖层遮挡） -->
								<Border x:Name="StyleHeaderSpacer"
										Background="{DynamicResource SecondaryRegionBrush}">
									<StackPanel>
										<Border Padding="8,7,8,7"
												BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
											<TextBlock Text="样式表字体替换"
													   FontSize="11" FontWeight="SemiBold"
													   Foreground="{DynamicResource PrimaryTextBrush}" Visibility="Hidden"/>
										</Border>
										<Border Padding="8,5,24,5"
												BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
											<TextBlock Text=" " FontSize="10" Visibility="Hidden"/>
										</Border>
									</StackPanel>
								</Border>

								<!-- 样式表数据行 -->
								<ItemsControl x:Name="StyleDataRows" ItemsSource="{Binding Items}">
									<ItemsControl.ItemTemplate>
										<DataTemplate>
											<Border Padding="8,1"
													BorderThickness="3,0,0,0">
												<Border.Style>
													<Style TargetType="Border">
														<Setter Property="BorderBrush" Value="Transparent"/>
														<Style.Triggers>
															<DataTrigger Binding="{Binding IsReplaced}" Value="False">
																<Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
																<Setter Property="Background" Value="#08FF4444"/>
															</DataTrigger>
														</Style.Triggers>
													</Style>
												</Border.Style>
												<Grid MinHeight="24">
													<Grid.ColumnDefinitions>
														<ColumnDefinition Width="3*"/>
														<ColumnDefinition Width="100"/>
														<ColumnDefinition Width="2*"/>
														<ColumnDefinition Width="2*"/>
													</Grid.ColumnDefinitions>
													<Border Grid.ColumnSpan="4" VerticalAlignment="Bottom" Height="1"
															Background="{DynamicResource BorderBrush}" Margin="-11,0,-8,-2" />
													<TextBlock Grid.Column="0" Text="{Binding StyleName}"
															   FontSize="11" VerticalAlignment="Center"
															   TextTrimming="CharacterEllipsis"
															   ToolTip="{Binding StyleName}">
														<TextBlock.Style>
															<Style TargetType="TextBlock">
																<Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
																<Style.Triggers>
																	<DataTrigger Binding="{Binding IsReplaced}" Value="False">
																		<Setter Property="FontWeight" Value="SemiBold"/>
																	</DataTrigger>
																</Style.Triggers>
															</Style>
														</TextBlock.Style>
													</TextBlock>
													<Border Grid.Column="1" CornerRadius="3"
															Padding="4,1"
															HorizontalAlignment="Center" VerticalAlignment="Center">
														<Border.Style>
															<Style TargetType="Border">
																<Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
																<Style.Triggers>
																	<DataTrigger Binding="{Binding FontCategory}" Value="TrueType">
																		<Setter Property="Background" Value="{StaticResource TrueTypeBrush}"/>
																	</DataTrigger>
																	<DataTrigger Binding="{Binding FontCategory}" Value="SHX大字体">
																		<Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
																	</DataTrigger>
																</Style.Triggers>
															</Style>
														</Border.Style>
														<TextBlock Text="{Binding FontCategory}" FontSize="9"
																   Foreground="White"/>
													</Border>
													<TextBlock Grid.Column="2" Text="{Binding DisplayMissingFontName}"
															   FontSize="11" VerticalAlignment="Center"
															   TextTrimming="CharacterEllipsis"
															   ToolTip="{Binding MissingFontName}">
														<TextBlock.Style>
															<Style TargetType="TextBlock">
																<Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
																<Style.Triggers>
																	<DataTrigger Binding="{Binding IsReplaced}" Value="True">
																		<Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
																	</DataTrigger>
																</Style.Triggers>
															</Style>
														</TextBlock.Style>
													</TextBlock>
													<ComboBox Grid.Column="3" IsEditable="True"
															  IsTextSearchEnabled="True"
															  Height="22" Margin="4,0,2,0"
															  BorderBrush="#999"
															  hc:InfoElement.Placeholder="选择字体..."
															  Style="{StaticResource ComboBoxExtend}"
															  ItemsSource="{Binding AvailableFonts}"
															  Text="{Binding SelectedReplacement, UpdateSourceTrigger=PropertyChanged}"
															  Loaded="OnComboBoxLoaded"/>
												</Grid>
											</Border>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</StackPanel>

							<!-- ─── MText内联字体映射区块 ─── -->
							<StackPanel x:Name="FontMappingSection"
										Visibility="{Binding HasFontMappings, Converter={StaticResource BoolToVis}}">
								<Border x:Name="FontMappingHeaderMarker"
										Background="{DynamicResource SecondaryRegionBrush}">
									<StackPanel>
										<Border Padding="8,7,8,7"
												BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
											<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
												<TextBlock Text="MText内联字体映射"
														   FontSize="11" FontWeight="SemiBold"
														   Foreground="{DynamicResource PrimaryTextBrush}"/>
												<Border CornerRadius="3" Padding="5,1" Margin="8,0,0,0"
														Background="{StaticResource RuntimeMappingBrush}">
													<TextBlock Text="{Binding FontMappingCount}" FontSize="9" Foreground="White"/>
												</Border>
											</StackPanel>
										</Border>
										<Border Padding="11,5,8,5"
												BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
											<Grid>
												<Grid.ColumnDefinitions>
													<ColumnDefinition Width="3*"/>
													<ColumnDefinition Width="150"/>
													<ColumnDefinition Width="3*"/>
													<ColumnDefinition Width="84"/>
												</Grid.ColumnDefinitions>
												<TextBlock Grid.Column="0" Text="缺失字体" FontSize="10"
														   Foreground="{DynamicResource SecondaryTextBrush}"
														   HorizontalAlignment="Left" VerticalAlignment="Center"/>
												<TextBlock Grid.Column="1" Text="类型" FontSize="10"
														   Foreground="{DynamicResource SecondaryTextBrush}"
														   HorizontalAlignment="Center" VerticalAlignment="Center"/>
												<TextBlock Grid.Column="2" Text="映射字体" FontSize="10"
														   Foreground="{DynamicResource SecondaryTextBrush}"
														   HorizontalAlignment="Left" VerticalAlignment="Center"/>
												<TextBlock Grid.Column="3" Text="Hook" FontSize="10"
														   Foreground="{DynamicResource SecondaryTextBrush}"
														   HorizontalAlignment="Left" VerticalAlignment="Center"/>
											</Grid>
										</Border>
									</StackPanel>
								</Border>

								<ItemsControl ItemsSource="{Binding FontMappingItems}">
									<ItemsControl.ItemTemplate>
										<DataTemplate>
											<Border Padding="8,1" BorderThickness="3,0,0,0">
												<Border.Style>
													<Style TargetType="Border">
														<Setter Property="BorderBrush" Value="{StaticResource RuntimeMappingBrush}"/>
														<Setter Property="Background" Value="#0500897B"/>
														<Style.Triggers>
															<DataTrigger Binding="{Binding IsFailed}" Value="True">
																<Setter Property="BorderBrush" Value="{DynamicResource DangerBrush}"/>
																<Setter Property="Background" Value="#08FF4444"/>
															</DataTrigger>
														</Style.Triggers>
													</Style>
												</Border.Style>
												<Grid MinHeight="28">
													<Grid.ColumnDefinitions>
														<ColumnDefinition Width="3*"/>
														<ColumnDefinition Width="150"/>
														<ColumnDefinition Width="3*"/>
														<ColumnDefinition Width="84"/>
													</Grid.ColumnDefinitions>
													<Border Grid.ColumnSpan="4" VerticalAlignment="Bottom" Height="1"
															Background="{DynamicResource BorderBrush}" Margin="-11,0,-8,-2" />
													<TextBlock Grid.Column="0" Text="{Binding MissingFont}"
															   FontSize="11" VerticalAlignment="Center"
															   Foreground="{DynamicResource SecondaryTextBrush}"
															   TextTrimming="CharacterEllipsis"
															   ToolTip="{Binding MissingFont}"/>
													<Border Grid.Column="1" CornerRadius="3"
															Padding="4,1"
															HorizontalAlignment="Center" VerticalAlignment="Center">
														<Border.Style>
															<Style TargetType="Border">
																<Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
																<Style.Triggers>
																	<DataTrigger Binding="{Binding FontType}" Value="TrueType字体">
																		<Setter Property="Background" Value="{StaticResource TrueTypeBrush}"/>
																	</DataTrigger>
																	<DataTrigger Binding="{Binding FontType}" Value="SHX大字体">
																		<Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
																	</DataTrigger>
																</Style.Triggers>
															</Style>
														</Border.Style>
														<TextBlock Text="{Binding FontType}" FontSize="9" Foreground="White"/>
													</Border>
													<TextBlock Grid.Column="2" Text="{Binding DisplayReplacementFont}"
															   FontSize="11" VerticalAlignment="Center"
															   HorizontalAlignment="Left"
															   TextTrimming="CharacterEllipsis"
															   ToolTip="{Binding ReplacementToolTip}">
														<TextBlock.Style>
															<Style TargetType="TextBlock">
																<Setter Property="Foreground" Value="{StaticResource RuntimeMappingBrush}"/>
																<Style.Triggers>
																	<DataTrigger Binding="{Binding IsFailed}" Value="True">
																		<Setter Property="Foreground" Value="{DynamicResource DangerBrush}"/>
																		<Setter Property="FontWeight" Value="SemiBold"/>
																	</DataTrigger>
																</Style.Triggers>
															</Style>
														</TextBlock.Style>
													</TextBlock>
													<TextBlock Grid.Column="3" Text="{Binding ExecutingHook}"
															   FontSize="10" VerticalAlignment="Center"
															   HorizontalAlignment="Left"
															   Foreground="{DynamicResource SecondaryTextBrush}"
															   TextTrimming="CharacterEllipsis"
															   ToolTip="{Binding Status}"/>
												</Grid>
											</Border>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</StackPanel>

						</StackPanel>
					</ScrollViewer>
				</Grid>
			</Border>

			<!-- 底部：左侧批量操作 + 右侧按钮 -->
			<DockPanel Grid.Row="6">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
					<Button Content="应用替换"
							MinWidth="80" Height="32" FontSize="12"
							Margin="0,0,10,0"
							Style="{StaticResource ButtonPrimary}"
							hc:BorderElement.CornerRadius="6"
							Command="{Binding ApplyCommand}"/>
                    <Button Content="关闭"
                            MinWidth="80" Height="32" FontSize="12"
                            hc:BorderElement.CornerRadius="6"
                            Command="{Binding CloseCommand}"/>
                </StackPanel>
				<StackPanel Orientation="Horizontal" VerticalAlignment="Center"
							IsEnabled="{Binding HasItems}"
							Visibility="{Binding HasAnyContent, Converter={StaticResource BoolToVis}}">
					<ComboBox Width="110" Height="28" IsEditable="True" IsTextSearchEnabled="True"
							  IsEnabled="{Binding HasShx}"
							  BorderBrush="#999"
							  hc:InfoElement.Placeholder="SHX主字体"
							  Style="{StaticResource ComboBoxExtend}"
							  ItemsSource="{Binding AvailableMainFonts}"
							  Text="{Binding BatchShxFont, UpdateSourceTrigger=PropertyChanged}"
							  Loaded="OnComboBoxLoaded"/>
					<ComboBox Width="110" Height="28" Margin="4,0,0,0" IsEditable="True" IsTextSearchEnabled="True"
							  IsEnabled="{Binding HasBigFont}"
							  BorderBrush="#999"
							  hc:InfoElement.Placeholder="SHX大字体"
							  Style="{StaticResource ComboBoxExtend}"
							  ItemsSource="{Binding AvailableBigFonts}"
							  Text="{Binding BatchBigFont, UpdateSourceTrigger=PropertyChanged}"
							  Loaded="OnComboBoxLoaded"/>
					<ComboBox Width="120" Height="28" Margin="4,0,0,0" IsEditable="True" IsTextSearchEnabled="True"
							  IsEnabled="{Binding HasTrueType}"
							  BorderBrush="#999"
							  hc:InfoElement.Placeholder="TrueType字体"
							  Style="{StaticResource ComboBoxExtend}"
							  ItemsSource="{Binding AvailableTrueTypeFonts}"
							  Text="{Binding BatchTrueTypeFont, UpdateSourceTrigger=PropertyChanged}"
							  Loaded="OnComboBoxLoaded"/>
                    <Button Content="填充" Height="28" FontSize="11"
                            Margin="5,0,0,0" Padding="6,0"
                            hc:BorderElement.CornerRadius="4"
                            Command="{Binding ApplyBatchCommand}"/>
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</Window>
