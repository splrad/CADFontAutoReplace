<Window x:Class="AFR.UI.DbTextLabelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="AFR - 单行文字确认"
        Width="560"
        Height="540"
        MinWidth="480"
        MinHeight="460"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

            <Style x:Key="SectionLabelStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            </Style>

            <Style x:Key="HelpTextStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="10"
            Background="{DynamicResource RegionBrush}"
            TextElement.FontFamily="鸿蒙黑体, 微软雅黑, 黑体"
            MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Grid Margin="22,20,22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="确认单行文字"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>
            <TextBlock Text="请核对识别结果，必要时修改正确文字。"
                       Margin="0,5,0,0"
                       Style="{StaticResource HelpTextStyle}"/>
        </StackPanel>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False">
            <StackPanel>
                <TextBlock Text="当前图纸中的文字"
                           Style="{StaticResource SectionLabelStyle}"/>
                <TextBox Margin="0,7,0,16"
                         MinHeight="72"
                         MaxHeight="120"
                         IsReadOnly="True"
                         Text="{Binding CurrentText, Mode=OneWay}"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>

                <Grid Margin="0,0,0,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="7"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="8"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="True">
                        <Button DockPanel.Dock="Right"
                                MinWidth="86"
                                Height="28"
                                Margin="12,0,0,0"
                                Command="{Binding UseCandidateCommand}"
                                hc:BorderElement.CornerRadius="6"
                                Content="采用建议"/>
                        <TextBlock Text="建议修复为"
                                   Style="{StaticResource SectionLabelStyle}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>

                    <TextBox Grid.Row="2"
                             MinHeight="56"
                             MaxHeight="100"
                             IsReadOnly="True"
                             Text="{Binding CandidatePreview, Mode=OneWay}"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>

                    <ComboBox Grid.Row="4"
                              Height="30"
                              IsEnabled="{Binding HasCandidates}"
                              ItemsSource="{Binding Candidates}"
                              SelectedItem="{Binding SelectedCandidate, Mode=TwoWay}"
                              DisplayMemberPath="Text"
                              Visibility="{Binding HasCandidates, Converter={StaticResource BoolToVis}}"/>
                </Grid>

                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Right"
                               Text="不能为空"
                               FontSize="11"
                               Foreground="{DynamicResource DangerBrush}"
                               Visibility="{Binding HasSelectedTextError, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Text="正确文字"
                               Style="{StaticResource SectionLabelStyle}"/>
                </DockPanel>

                <TextBox x:Name="SelectedTextBox"
                         Margin="0,7,0,14"
                         MinHeight="96"
                         AcceptsReturn="True"
                         Text="{Binding SelectedText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>

                <TextBlock Text="备注（可选）"
                           Style="{StaticResource SectionLabelStyle}"/>
                <TextBox Margin="0,7,0,16"
                         Height="32"
                         Text="{Binding Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Disabled"/>

                <Expander Header="详细信息"
                          FontSize="12"
                          Foreground="{DynamicResource SecondaryTextBrush}">
                    <StackPanel Margin="0,8,0,0">
                        <TextBlock Text="{Binding Metadata}"
                                   Style="{StaticResource HelpTextStyle}"/>
                        <TextBox Margin="0,8,0,0"
                                 MinHeight="56"
                                 MaxHeight="120"
                                 IsReadOnly="True"
                                 Text="{Binding EvidenceText, Mode=OneWay}"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"/>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </ScrollViewer>

        <DockPanel Grid.Row="4" LastChildFill="False">
            <Button DockPanel.Dock="Right"
                    MinWidth="78"
                    Height="34"
                    Margin="10,0,0,0"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    hc:BorderElement.CornerRadius="6"
                    Content="取消"/>

            <StackPanel DockPanel.Dock="Left"
                        Orientation="Horizontal">
                <Button MinWidth="96"
                        Height="34"
                        Margin="0,0,10,0"
                        Style="{StaticResource ButtonPrimary}"
                        Command="{Binding RepairCommand}"
                        IsDefault="True"
                        hc:BorderElement.CornerRadius="6"
                        Content="保存修改"/>
                <Button MinWidth="86"
                        Height="34"
                        Margin="0,0,10,0"
                        Command="{Binding KeepCommand}"
                        hc:BorderElement.CornerRadius="6"
                        Content="不修改"/>
                <Button MinWidth="104"
                        Height="34"
                        Command="{Binding GlyphIssueCommand}"
                        hc:BorderElement.CornerRadius="6"
                        Content="字体问题"/>
            </StackPanel>
        </DockPanel>
    </Grid>
    </Border>
</Window>
