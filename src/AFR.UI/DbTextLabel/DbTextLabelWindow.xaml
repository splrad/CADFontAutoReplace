<Window x:Class="AFR.UI.DbTextLabelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="AFR - DBText 人工确认"
        Width="760"
        Height="660"
        MinWidth="640"
        MinHeight="540"
        WindowStartupLocation="Manual"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Background="{DynamicResource RegionBrush}"
        TextElement.FontFamily="鸿蒙黑体, 微软雅黑, 黑体"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>

            <Style x:Key="CardBorderStyle" TargetType="{x:Type Border}">
                <Setter Property="CornerRadius" Value="8"/>
                <Setter Property="Padding" Value="14"/>
                <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
            </Style>

            <Style x:Key="SectionTitleStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            </Style>

            <Style x:Key="MutedTextStyle" TargetType="{x:Type TextBlock}">
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True">
            <Border DockPanel.Dock="Right"
                    CornerRadius="6"
                    Padding="9,4"
                    Margin="16,2,0,0"
                    Background="{DynamicResource PrimaryBrush}">
                <TextBlock Text="{Binding CandidateCountText}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="White"/>
            </Border>

            <StackPanel>
                <TextBlock Text="DBText 人工确认"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Text="{Binding Metadata}"
                           Margin="0,5,0,0"
                           Style="{StaticResource MutedTextStyle}"/>
            </StackPanel>
        </DockPanel>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.08*" MinWidth="280"/>
                    <ColumnDefinition Width="14"/>
                    <ColumnDefinition Width="*" MinWidth="280"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Row="0"
                        Grid.Column="0"
                        Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="当前文本"
                                   Style="{StaticResource SectionTitleStyle}"/>
                        <TextBox Grid.Row="2"
                                 MinHeight="82"
                                 MaxHeight="150"
                                 IsReadOnly="True"
                                 Text="{Binding CurrentText}"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"/>

                        <DockPanel Grid.Row="4" LastChildFill="True">
                            <Button DockPanel.Dock="Right"
                                    MinWidth="96"
                                    Height="30"
                                    Margin="12,0,0,0"
                                    Command="{Binding UseCandidateCommand}"
                                    hc:BorderElement.CornerRadius="6">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8AD;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="12"
                                               Margin="0,0,5,0"/>
                                    <TextBlock Text="使用候选"/>
                                </StackPanel>
                            </Button>
                            <TextBlock Text="候选文本"
                                       Style="{StaticResource SectionTitleStyle}"
                                       VerticalAlignment="Center"/>
                        </DockPanel>

                        <Grid Grid.Row="6" MinHeight="210">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <ListBox ItemsSource="{Binding Candidates}"
                                         SelectedItem="{Binding SelectedCandidate, Mode=TwoWay}"
                                         Visibility="{Binding HasCandidates, Converter={StaticResource BoolToVis}}"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="{x:Type ListBoxItem}">
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="2,3"
                                                    Padding="9,7"
                                                    CornerRadius="6"
                                                    BorderBrush="{DynamicResource BorderBrush}"
                                                    BorderThickness="1"
                                                    Background="{DynamicResource RegionBrush}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="4"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Grid Grid.Row="0"
                                                          Grid.Column="0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <Border Grid.Column="0"
                                                                CornerRadius="4"
                                                                Padding="6,2"
                                                                Margin="0,0,8,0"
                                                                Background="{DynamicResource PrimaryBrush}">
                                                            <TextBlock Text="{Binding SourceDisplay}"
                                                                       FontSize="10"
                                                                       Foreground="White"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Text}"
                                                                   FontSize="13"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                                   TextWrapping="Wrap"/>
                                                    </Grid>

                                                    <Border Grid.Row="0"
                                                            Grid.Column="1"
                                                            CornerRadius="4"
                                                            Padding="6,2"
                                                            Margin="8,0,0,0"
                                                            Background="{DynamicResource SuccessBrush}"
                                                            Visibility="{Binding HasNeuralScore, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="{Binding ScoreText}"
                                                                   FontSize="10"
                                                                   Foreground="White"/>
                                                    </Border>

                                                    <TextBlock Grid.Row="2"
                                                               Grid.Column="0"
                                                               Grid.ColumnSpan="2"
                                                               Text="{Binding ReasonDisplay}"
                                                               Style="{StaticResource MutedTextStyle}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Border CornerRadius="6"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1"
                                        Background="{DynamicResource RegionBrush}"
                                        Visibility="{Binding HasNoCandidates, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="无候选"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Style="{StaticResource MutedTextStyle}"/>
                                </Border>
                            </Grid>

                            <TextBox Grid.Row="2"
                                     MinHeight="72"
                                     MaxHeight="120"
                                     IsReadOnly="True"
                                     Text="{Binding CandidatePreview}"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"/>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="0"
                        Grid.Column="2"
                        Style="{StaticResource CardBorderStyle}">
                    <Grid FocusManager.FocusedElement="{Binding ElementName=SelectedTextBox}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="14"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" LastChildFill="True">
                            <TextBlock DockPanel.Dock="Right"
                                       Text="正确文本不能为空"
                                       FontSize="11"
                                       Foreground="{DynamicResource DangerBrush}"
                                       Visibility="{Binding HasSelectedTextError, Converter={StaticResource BoolToVis}}"/>
                            <TextBlock Text="正确文本"
                                       Style="{StaticResource SectionTitleStyle}"/>
                        </DockPanel>

                        <TextBox x:Name="SelectedTextBox"
                                 Grid.Row="2"
                                 MinHeight="220"
                                 AcceptsReturn="True"
                                 Text="{Binding SelectedText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"/>

                        <TextBlock Grid.Row="4"
                                   Text="备注"
                                   Style="{StaticResource SectionTitleStyle}"/>
                        <TextBox Grid.Row="6"
                                 Height="34"
                                 Text="{Binding Note, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Disabled"/>
                    </Grid>
                </Border>

                <Border Grid.Row="2"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Style="{StaticResource CardBorderStyle}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="8"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="证据"
                                   Style="{StaticResource SectionTitleStyle}"/>
                        <TextBox Grid.Row="2"
                                 MinHeight="72"
                                 MaxHeight="150"
                                 IsReadOnly="True"
                                 Text="{Binding EvidenceText}"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"/>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <DockPanel Grid.Row="4" LastChildFill="False">
            <Button DockPanel.Dock="Right"
                    MinWidth="86"
                    Height="34"
                    Margin="12,0,0,0"
                    Command="{Binding CancelCommand}"
                    IsCancel="True"
                    hc:BorderElement.CornerRadius="6">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE711;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               Margin="0,0,5,0"/>
                    <TextBlock Text="取消"/>
                </StackPanel>
            </Button>

            <StackPanel DockPanel.Dock="Left"
                        Orientation="Horizontal">
                <Button MinWidth="126"
                        Height="34"
                        Margin="0,0,10,0"
                        Style="{StaticResource ButtonPrimary}"
                        Command="{Binding RepairCommand}"
                        IsDefault="True"
                        hc:BorderElement.CornerRadius="6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE73E;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Margin="0,0,5,0"/>
                        <TextBlock Text="写回正确文本"/>
                    </StackPanel>
                </Button>
                <Button MinWidth="100"
                        Height="34"
                        Margin="0,0,10,0"
                        Command="{Binding KeepCommand}"
                        hc:BorderElement.CornerRadius="6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8FB;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Margin="0,0,5,0"/>
                        <TextBlock Text="保持当前"/>
                    </StackPanel>
                </Button>
                <Button MinWidth="104"
                        Height="34"
                        Command="{Binding GlyphIssueCommand}"
                        hc:BorderElement.CornerRadius="6">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8D2;"
                                   FontFamily="Segoe MDL2 Assets"
                                   FontSize="12"
                                   Margin="0,0,5,0"/>
                        <TextBlock Text="字体问题"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
