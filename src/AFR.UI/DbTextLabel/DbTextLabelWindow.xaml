<Window x:Class="AFR.UI.DbTextLabelWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AFR — DBText 人工确认"
        Width="620" Height="520"
        WindowStartupLocation="Manual"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="DBText 人工确认"
                       FontSize="17"
                       FontWeight="SemiBold"/>
            <TextBlock x:Name="MetadataText"
                       Margin="0,4,0,0"
                       FontSize="12"
                       Foreground="#666666"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Row="2"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="86"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="当前文本"
                           FontWeight="SemiBold"
                           VerticalAlignment="Top"/>
                <TextBox x:Name="CurrentTextBox"
                         Grid.Row="0" Grid.Column="1"
                         MinHeight="54"
                         IsReadOnly="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>

                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="候选文本"
                           FontWeight="SemiBold"
                           VerticalAlignment="Top"/>
                <DockPanel Grid.Row="2" Grid.Column="1">
                    <Button x:Name="UseCandidateButton"
                            DockPanel.Dock="Right"
                            Width="76"
                            Height="26"
                            Margin="8,0,0,0"
                            Content="使用候选"
                            Click="OnUseCandidate"/>
                    <TextBox x:Name="CandidateTextBox"
                             MinHeight="54"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"/>
                </DockPanel>

                <TextBlock Grid.Row="4" Grid.Column="0"
                           Text="证据"
                           FontWeight="SemiBold"
                           VerticalAlignment="Top"/>
                <TextBlock x:Name="EvidenceText"
                           Grid.Row="4" Grid.Column="1"
                           FontSize="12"
                           Foreground="#666666"
                           TextWrapping="Wrap"/>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                CornerRadius="4"
                Padding="10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="正确文本"
                           FontWeight="SemiBold"/>
                <TextBox x:Name="SelectedTextBox"
                         Grid.Row="2"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"/>
                <TextBox x:Name="NoteTextBox"
                         Grid.Row="4"
                         Height="28"
                         TextWrapping="NoWrap"/>
            </Grid>
        </Border>

        <DockPanel Grid.Row="6" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left"
                        Orientation="Horizontal">
                <Button Width="104"
                        Height="30"
                        Margin="0,0,8,0"
                        Content="写回正确文本"
                        Click="OnRepair"/>
                <Button Width="86"
                        Height="30"
                        Margin="0,0,8,0"
                        Content="保持当前"
                        Click="OnKeep"/>
                <Button Width="96"
                        Height="30"
                        Content="字体问题"
                        Click="OnGlyphIssue"/>
            </StackPanel>

            <Button DockPanel.Dock="Right"
                    Width="72"
                    Height="30"
                    Content="取消"
                    Click="OnCancel"/>
        </DockPanel>
    </Grid>
</Window>
