<Window x:Class="AFR.Deployer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AFR.Deployer.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="using:Microsoft.UI.Xaml.Controls"
        mc:Ignorable="d">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*"    />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- TitleBar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="40"
              Background="Transparent"
              VerticalAlignment="Top">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0">
                <Image Source="ms-appx:///Assets/app.ico" Width="16" Height="16" Margin="0,0,10,0" />
                <TextBlock Text="AFR 部署工具"
                           VerticalAlignment="Center"
                           Style="{ThemeResource CaptionTextBlockStyle}" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="24,8,24,16">
            <StackPanel Spacing="16">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="4">
                        <TextBlock Text="插件部署"
                                   Style="{ThemeResource TitleTextBlockStyle}" />
                        <TextBlock Text="选中支持的 AutoCAD 版本，一键完成插件 DLL 的部署与注册。未安装的版本将自动禁用。"
                                   Style="{ThemeResource BodyTextBlockStyle}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            VerticalAlignment="Top"
                            Command="{x:Bind ViewModel.RefreshCommand}">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                            <TextBlock Text="刷新" />
                        </StackPanel>
                    </Button>
                </Grid>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*"    />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Padding="20,16,20,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10"
                                        VerticalAlignment="Center">
                                <TextBlock Text="支持的 AutoCAD 版本"
                                           Style="{ThemeResource SubtitleTextBlockStyle}" />
                                <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                        CornerRadius="10" Padding="8,2"
                                        VerticalAlignment="Center">
                                    <TextBlock FontSize="11"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                        <Run Text="{x:Bind ViewModel.CadEntries.Count, Mode=OneWay}" /><Run Text=" 项" />
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                <HyperlinkButton Content="全选"
                                                 Command="{x:Bind ViewModel.SelectAllCommand}"
                                                 CommandParameter="true" />
                                <HyperlinkButton Content="取消全选"
                                                 Command="{x:Bind ViewModel.SelectAllCommand}"
                                                 CommandParameter="false" />
                            </StackPanel>
                        </Grid>

                        <controls:ItemsRepeaterScrollHost Grid.Row="1"><ScrollViewer HorizontalScrollMode="Disabled" VerticalScrollBarVisibility="Auto"><controls:ItemsRepeater ItemsSource="{x:Bind ViewModel.CadEntries}"
                                                    Margin="16,0,16,16">
                                <controls:ItemsRepeater.Layout>
                                    <controls:UniformGridLayout MinItemWidth="240"
                                                                MinItemHeight="120"
                                                                MinRowSpacing="12"
                                                                MinColumnSpacing="12"
                                                                MaximumRowsOrColumns="3"
                                                                ItemsStretch="Fill" />
                                </controls:ItemsRepeater.Layout>
                                <controls:ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CadEntryViewModel">
                                        <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                                BorderThickness="1"
                                                CornerRadius="6"
                                                Padding="14"
                                                Background="{ThemeResource SubtleFillColorTransparentBrush}"
                                                IsHitTestVisible="{x:Bind IsEnabled, Mode=OneWay}"
                                                Opacity="{Binding IsEnabled, Converter={StaticResource AvailabilityToOpacity}}">
                                            <Grid RowSpacing="8">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <Grid Grid.Row="0" ColumnSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0"
                                                              IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                                              IsEnabled="{x:Bind IsEnabled, Mode=OneWay}"
                                                              MinWidth="0"
                                                              VerticalAlignment="Center" />
                                                    <Border Grid.Column="1"
                                                            Width="32" Height="32" CornerRadius="6"
                                                            Background="#E53935"
                                                            VerticalAlignment="Center">
                                                        <TextBlock Text="{x:Bind BrandInitial}"
                                                                   Foreground="White"
                                                                   FontWeight="SemiBold"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                    </Border>
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="0">
                                                        <TextBlock Text="{x:Bind DisplayName}"
                                                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{x:Bind Profile}"
                                                                   FontSize="11"
                                                                   FontFamily="Consolas, Microsoft YaHei UI"
                                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                   TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Grid>

                                                <Border Grid.Row="1"
                                                        Padding="8,3" CornerRadius="10"
                                                        HorizontalAlignment="Left"
                                                        Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                                                                 Fill="{Binding Status, Converter={StaticResource StatusToBrush}}" />
                                                        <TextBlock Text="{x:Bind StatusText, Mode=OneWay}"
                                                                   FontSize="12"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Border>

                                                <TextBlock Grid.Row="2"
                                                           FontSize="11"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                                    <Run Text="已安装版本：" /><Run Text="{x:Bind InstalledVersion, Mode=OneWay}" />
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </controls:ItemsRepeater.ItemTemplate>
                            </controls:ItemsRepeater></ScrollViewer></controls:ItemsRepeaterScrollHost>
                    </Grid>
                </Border>

                <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel Padding="20" Spacing="14">
                        <TextBlock Text="安装目录"
                                   Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{x:Bind ViewModel.DeployPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="输入或浏览目标目录…"
                                     FontFamily="Consolas, Microsoft YaHei UI" />
                            <Button Grid.Column="1"
                                    Content="浏览…"
                                    Command="{x:Bind ViewModel.BrowseCommand}"
                                    MinWidth="88" />
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       TextWrapping="Wrap"
                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                勾选已安装的版本后，点击"安装"将 DLL 复制到目录并写入注册表；点击"卸载"删除 DLL 并清理注册表。
                            </TextBlock>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                                <Button Content="卸载"
                                        Command="{x:Bind ViewModel.UninstallCommand}"
                                        MinWidth="88" />
                                <Button Content="安装"
                                        Command="{x:Bind ViewModel.InstallCommand}"
                                        Style="{ThemeResource AccentButtonStyle}"
                                        MinWidth="88" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                Padding="20,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Ellipse Width="8" Height="8" VerticalAlignment="Center"
                         Fill="{Binding IsCadRunning, Converter={StaticResource RunningToBrush}}" />
                <TextBlock Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                           VerticalAlignment="Center"
                           Style="{ThemeResource CaptionTextBlockStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</Window>