<ui:FluentWindow x:Class="AFR.Deployer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AFR.Deployer.ViewModels"
        xmlns:models="clr-namespace:AFR.Deployer.Models"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AFR 部署工具"
        Width="880" Height="640"
        MinWidth="880" MinHeight="640"
        MaxWidth="1040" MaxHeight="760"
        Icon="pack://application:,,,/Icons/app.ico"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        RenderOptions.ClearTypeHint="Enabled">

    <ui:FluentWindow.Resources>
        <!--
            状态调色板：3 种形态共用。所有 Brush 在此集中定义，方便统一调色。
            -  Current  绿系：图标/文字 #10884B；徽章底 #E6F4EC
            -  Outdated 橙系：图标/文字 #C48300；徽章底 #FCEFD7
            -  Pending  蓝系：图标/文字 #0F6CBD —— "CAD 已装但插件待安装"，提示用户接下来要操作
            -  NotInst  灰系：图标/文字 #8A8A8A —— "未检测到 CAD"，整张卡再叠 0.55 透明度
            -  DllMiss  红系：图标/文字 #C42B1C
        -->
        <SolidColorBrush x:Key="StatusCurrentBrush"  Color="#10884B" />
        <SolidColorBrush x:Key="StatusOutdatedBrush" Color="#C48300" />
        <SolidColorBrush x:Key="StatusPendingBrush"  Color="#0F6CBD" />
        <SolidColorBrush x:Key="StatusNotInstBrush"  Color="#8A8A8A" />
        <SolidColorBrush x:Key="StatusDllMissBrush"  Color="#C42B1C" />

        <SolidColorBrush x:Key="BadgeCurrentBgBrush"   Color="#E6F4EC" />
        <SolidColorBrush x:Key="BadgeOutdatedBgBrush"  Color="#FCEFD7" />

        <!--
            卡片样式：使用 ToggleButton 实现整卡可点击。
            - 圆角 10、浅灰底、1px 描边；Hover 阴影增强 + 轻微上浮（Margin Y 调整模拟 translate）
            - IsChecked / Status 视觉反馈仅微调描边色，主信息由模板内部的图标/文字承担
            - Disabled（未检测到 CAD）：保留外观，仅降透明度
        -->
        <Style x:Key="CadCardStyle" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="True" />
            <Setter Property="Margin" Value="5" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="#FAFAFA" />
            <Setter Property="BorderBrush" Value="#E5E5E5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <!-- Effect 提到 Border 上：BlurRadius/Opacity 在触发器里调整以实现"隆起" -->
                        <Border x:Name="PART_Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect x:Name="PART_Shadow"
                                                  BlurRadius="6"
                                                  ShadowDepth="1"
                                                  Direction="270"
                                                  Color="#000000"
                                                  Opacity="0.06" />
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PART_Border" Property="Background" Value="#FFFFFF" />
                                <Setter TargetName="PART_Border" Property="BorderBrush" Value="#D0D0D0" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PART_Shadow"
                                                             Storyboard.TargetProperty="BlurRadius"
                                                             To="14" Duration="0:0:0.12" />
                                            <DoubleAnimation Storyboard.TargetName="PART_Shadow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.18" Duration="0:0:0.12" />
                                            <DoubleAnimation Storyboard.TargetName="PART_Shadow"
                                                             Storyboard.TargetProperty="ShadowDepth"
                                                             To="3" Duration="0:0:0.12" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="PART_Shadow"
                                                             Storyboard.TargetProperty="BlurRadius"
                                                             To="6" Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="PART_Shadow"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.06" Duration="0:0:0.15" />
                                            <DoubleAnimation Storyboard.TargetName="PART_Shadow"
                                                             Storyboard.TargetProperty="ShadowDepth"
                                                             To="1" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="PART_Border" Property="BorderBrush" Value="#3FAE6A" />
                                <Setter TargetName="PART_Border" Property="BorderThickness" Value="1.5" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--
            CAD 品牌徽标占位容器：固定 44×44 仅显示 AutoCAD.ico。
            （早期 76×76 在 4 列布局下挤占文字区，导致 DisplayName 被裁成 "AutoCAD 2..."）
        -->
        <Style x:Key="BrandLogoStyle" TargetType="Grid">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
        </Style>

        <!--
            底部操作按钮通用样式：CAD 正在运行时按钮禁用，
            WPF-UI 默认 Primary 在 Disabled 下前景接近白色，与浅灰底重叠导致"看不见文字"，
            这里强制把禁用时的前景/图标改成可读的灰色。
        -->
        <Style x:Key="ActionButtonStyle" TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="#8A8A8A" />
                    <Setter Property="Opacity" Value="0.85" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题栏：使用项目主图标 app.ico -->
        <ui:TitleBar Grid.Row="0" Title="AFR 部署工具" ShowMaximize="False">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="pack://application:,,,/Icons/app.ico" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" Margin="24,8,24,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 顶部 header：左=图标+标题/副标题，右=检测摘要 chip（从底部状态栏上移，让职责更清晰：
                 顶部呈现"静态事实"，底部状态栏只承担"动态操作反馈"） -->
            <Grid Grid.Row="0" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="40" Height="40"
                            CornerRadius="10"
                            Background="#E8F1FB"
                            VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="Apps24"
                                       FontSize="22"
                                       Foreground="#0F6CBD"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="插件部署" FontSize="22" FontWeight="SemiBold" />
                            <Border Margin="10,2,0,0"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="6,1">
                                <TextBlock Text="{Binding DeployerVersion}"
                                           FontSize="11"
                                           FontFamily="Cascadia Mono, Consolas, Microsoft YaHei UI"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            </Border>
                        </StackPanel>
                        <TextBlock Text="选择 CAD 版本并一键安装 / 卸载 AFR 插件"
                                   FontSize="12"
                                   Margin="0,2,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="1"
                        VerticalAlignment="Center"
                        Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="12,7">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="CheckmarkCircle24"
                                       FontSize="15"
                                       Foreground="#10884B"
                                       VerticalAlignment="Center" />
                        <StackPanel Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DetectionSummary}"
                                       FontSize="12"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding PluginSummary}"
                                       FontSize="11"
                                       Margin="0,2,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Visibility="{Binding HasPluginSummary, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 中部：版本卡片容器 -->
            <Border Grid.Row="1"
                    Background="{DynamicResource LayerFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="9,7">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!--
                        卡片网格：固定 4 列；行数由 ItemsSource 数量自动决定，
                        最后一行允许不占满（UniformGrid 默认行为，空格保持空白即可）。
                        新增 CAD 版本时仅需在 CadDescriptors 中追加，无需改动 XAML。
                    -->
                    <ItemsControl Grid.Row="0" ItemsSource="{Binding CadEntries}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:CadEntryViewModel}">
                                <ToggleButton Style="{StaticResource CadCardStyle}"
                                              MinHeight="78"
                                              MaxHeight="110"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              IsEnabled="{Binding IsEnabled}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- 左：AutoCAD 品牌图标（外圈轻阴影，强化卡片层次） -->
                                        <Grid Grid.Column="0" Style="{StaticResource BrandLogoStyle}"
                                              VerticalAlignment="Center">
                                            <Image Source="pack://application:,,,/Icons/AutoCAD.ico"
                                                   Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image.Effect>
                                                    <DropShadowEffect BlurRadius="10"
                                                                      ShadowDepth="0"
                                                                      Color="#000000"
                                                                      Opacity="0.16" />
                                                </Image.Effect>
                                            </Image>
                                        </Grid>

                                        <!-- 右：标题 / 状态行（图标 + 文字）/ 副文本或版本+徽章 -->
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Margin="10,0,0,0">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />

                                            <!-- 状态行：SymbolIcon + StatusText，颜色随 Status 切换 -->
                                            <StackPanel x:Name="StatusRow"
                                                        Orientation="Horizontal"
                                                        Margin="0,4,0,0">
                                                <ui:SymbolIcon x:Name="StatusIcon"
                                                               Symbol="SubtractCircle24"
                                                               FontSize="14"
                                                               VerticalAlignment="Center"
                                                               Foreground="{StaticResource StatusNotInstBrush}" />
                                                <TextBlock x:Name="StatusLabel"
                                                           Text="{Binding StatusText}"
                                                           FontSize="11.5"
                                                           FontWeight="SemiBold"
                                                           Margin="5,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="{StaticResource StatusNotInstBrush}" />
                                            </StackPanel>

                                            <!-- 副文本（仅未安装 / DLL 缺失等无版本号场景显示） -->
                                            <TextBlock Text="{Binding SubText}"
                                                       Margin="0,3,0,0"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding ShowSubText, Converter={StaticResource BoolToVisibility}}" />

                                            <!-- 版本行（仅已安装两种态显示）：整块色徽章 = Tag 图标 + 版本号 + 最新版/旧版 -->
                                            <StackPanel x:Name="VersionRow"
                                                        Orientation="Horizontal"
                                                        Margin="0,3,0,0"
                                                        Visibility="{Binding ShowVersionRow, Converter={StaticResource BoolToVisibility}}">
                                                <Border x:Name="VersionBadge"
                                                        Padding="6,1"
                                                        CornerRadius="6"
                                                        VerticalAlignment="Center"
                                                        Background="{StaticResource BadgeCurrentBgBrush}">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <ui:SymbolIcon x:Name="VersionTagIcon"
                                                                       Symbol="Tag24"
                                                                       FontSize="12"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="{StaticResource StatusCurrentBrush}" />
                                                        <TextBlock x:Name="VersionNumberText"
                                                                   Text="{Binding InstalledVersion}"
                                                                   FontSize="11"
                                                                   FontFamily="Cascadia Mono, Consolas, Microsoft YaHei UI"
                                                                   FontWeight="SemiBold"
                                                                   Margin="4,0,6,0"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{StaticResource StatusCurrentBrush}" />
                                                        <TextBlock x:Name="VersionBadgeText"
                                                                   Text="{Binding BadgeText}"
                                                                   FontSize="10"
                                                                   FontWeight="SemiBold"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{StaticResource StatusCurrentBrush}" />
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </ToggleButton>

                                <!--
                                    DataTrigger 一次性切换状态相关的图标 / 颜色 / 徽章底色：
                                    - InstalledCurrent  绿（CheckmarkCircle24 + 最新版徽章）
                                    - InstalledOutdated 橙（Warning24       + 旧版徽章）
                                    - DllMissing        红（ErrorCircle24）
                                    - NotInstalled + CAD 已装   蓝（AddCircle24，强调"待你安装"）
                                    - NotInstalled + CAD 未装   灰（SubtractCircle24，默认值，无需 Trigger）
                                -->
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Status}" Value="InstalledCurrent">
                                        <Setter TargetName="StatusIcon"       Property="Symbol"     Value="CheckmarkCircle24" />
                                        <Setter TargetName="StatusIcon"       Property="Foreground" Value="{StaticResource StatusCurrentBrush}" />
                                        <Setter TargetName="StatusLabel"      Property="Foreground" Value="{StaticResource StatusCurrentBrush}" />
                                        <Setter TargetName="VersionBadge"     Property="Background" Value="{StaticResource BadgeCurrentBgBrush}" />
                                        <Setter TargetName="VersionBadgeText" Property="Foreground" Value="{StaticResource StatusCurrentBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="InstalledOutdated">
                                        <Setter TargetName="StatusIcon"       Property="Symbol"     Value="Warning24" />
                                        <Setter TargetName="StatusIcon"       Property="Foreground" Value="{StaticResource StatusOutdatedBrush}" />
                                        <Setter TargetName="StatusLabel"      Property="Foreground" Value="{StaticResource StatusOutdatedBrush}" />
                                        <Setter TargetName="VersionBadge"     Property="Background" Value="{StaticResource BadgeOutdatedBgBrush}" />
                                        <Setter TargetName="VersionTagIcon"   Property="Foreground" Value="{StaticResource StatusOutdatedBrush}" />
                                        <Setter TargetName="VersionNumberText" Property="Foreground" Value="{StaticResource StatusOutdatedBrush}" />
                                        <Setter TargetName="VersionBadgeText" Property="Foreground" Value="{StaticResource StatusOutdatedBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Status}" Value="DllMissing">
                                        <Setter TargetName="StatusIcon"  Property="Symbol"     Value="ErrorCircle24" />
                                        <Setter TargetName="StatusIcon"  Property="Foreground" Value="{StaticResource StatusDllMissBrush}" />
                                        <Setter TargetName="StatusLabel" Property="Foreground" Value="{StaticResource StatusDllMissBrush}" />
                                    </DataTrigger>
                                    <!-- CAD 已装但插件未装：升级为蓝色"待安装"，与"未检测到 CAD"的灰色明确区分 -->
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Status}" Value="NotInstalled" />
                                            <Condition Binding="{Binding IsCadInstalled}" Value="True" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter TargetName="StatusIcon"  Property="Symbol"     Value="AddCircle24" />
                                        <Setter TargetName="StatusIcon"  Property="Foreground" Value="{StaticResource StatusPendingBrush}" />
                                        <Setter TargetName="StatusLabel" Property="Foreground" Value="{StaticResource StatusPendingBrush}" />
                                    </MultiDataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- 底部：安装目录 + 操作按钮 -->
            <Border Grid.Row="2"
                    Margin="0,12,0,0"
                    Background="{DynamicResource LayerFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="安装目录"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0"
                                    Text="{Binding DeployPath, UpdateSourceTrigger=PropertyChanged}"
                                    FontFamily="Cascadia Mono, Consolas, Microsoft YaHei UI"
                                    PlaceholderText="部署目录" />
                        <ui:Button Grid.Column="1"
                                   Content="浏览"
                                   Appearance="Secondary"
                                   Icon="{ui:SymbolIcon FolderOpen24}"
                                   Command="{Binding BrowseCommand}"
                                   MinWidth="84"
                                   Margin="10,0,0,0" />
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="插件将部署到所选目录并写入注册表，下次启动 CAD 时生效。"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ui:Button Grid.Column="1"
                                   Content="卸载已选版本"
                                   Appearance="Secondary"
                                   Style="{StaticResource ActionButtonStyle}"
                                   Icon="{ui:SymbolIcon Delete24}"
                                   Command="{Binding UninstallCommand}"
                                   MinWidth="120" />
                        <ui:Button Grid.Column="2"
                                   Content="安装选中版本"
                                   Appearance="Primary"
                                   Style="{StaticResource ActionButtonStyle}"
                                   Icon="{ui:SymbolIcon ArrowDownload24}"
                                   Command="{Binding InstallCommand}"
                                   MinWidth="132"
                                   Margin="10,0,0,0" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- 状态栏：检测摘要已上移到 header chip；此处只承担"动态操作反馈"
             （CAD 运行警告 / 正在安装 / ✓ 成功），用左侧提示文字 + 右侧状态胶囊双指示提升可见性 -->
        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                Padding="24,11">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 左：固定语义标签，让用户清楚右侧是"当前状态" -->
                <TextBlock Grid.Column="0"
                           Text="当前状态"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                <!-- 右：操作状态胶囊（颜色随 StatusText 语义切换） -->
                <Border Grid.Column="2"
                        Background="{Binding StatusText, Converter={StaticResource StatusTextToBrush}, ConverterParameter=bg}"
                        CornerRadius="11"
                        Padding="12,5"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10"
                                 VerticalAlignment="Center"
                                 Fill="{Binding StatusText, Converter={StaticResource StatusTextToBrush}}" />
                        <TextBlock Text="{Binding StatusText}"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Margin="8,0,0,0"
                                   Foreground="{Binding StatusText, Converter={StaticResource StatusTextToBrush}}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
