<Window x:Class="AFR.Deployer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AFR.Deployer.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AFR 部署工具"
        Width="940" Height="600"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        Background="#FFF3F3F3"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <SolidColorBrush x:Key="CardBrush" Color="#FFFFFFFF" />
        <SolidColorBrush x:Key="CardStrokeBrush" Color="#FFE5E5E5" />
        <SolidColorBrush x:Key="SubtleBrush" Color="#FFF6F6F6" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#FF666666" />
        <Style TargetType="Button">
            <Setter Property="Padding" Value="14,6" />
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="BorderBrush" Value="#FFCCCCCC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Bd" Property="Background" Value="#FFEFEFEF" /></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter Property="Opacity" Value="0.5" /></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#FF0078D4" />
            <Setter Property="BorderBrush" Value="#FF0078D4" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Window.Resources>
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="24,16,24,16">
            <StackPanel>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="插件部署" FontSize="22" FontWeight="SemiBold" />
                        <TextBlock Text="选中支持的 AutoCAD 版本，一键完成插件 DLL 的部署与注册。未安装的版本将自动禁用。" Margin="0,4,0,0" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    <Button Grid.Column="1" VerticalAlignment="Top" Content="刷新" Command="{Binding RefreshCommand}" />
                </Grid>
                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardStrokeBrush}" BorderThickness="1" CornerRadius="8" Margin="0,0,0,16">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="20,16,20,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="支持的 AutoCAD 版本" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <Border Background="{StaticResource SubtleBrush}" CornerRadius="10" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock FontSize="11" Foreground="{StaticResource SecondaryTextBrush}"><Run Text="{Binding CadEntries.Count, Mode=OneWay}" /><Run Text=" 项" /></TextBlock>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="全选" Command="{Binding SelectAllCommand}" CommandParameter="true" BorderThickness="0" Background="Transparent" Foreground="#FF0078D4" Padding="6,2" Margin="2,0" />
                                <Button Content="取消全选" Command="{Binding SelectAllCommand}" CommandParameter="false" BorderThickness="0" Background="Transparent" Foreground="#FF0078D4" Padding="6,2" Margin="2,0" />
                            </StackPanel>
                        </Grid>
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding CadEntries}" Margin="16,0,16,16">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="3" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:CadEntryViewModel}">
                                    <Border BorderBrush="{StaticResource CardStrokeBrush}" BorderThickness="1" CornerRadius="6" Padding="14" Margin="6"
                                            Background="{Binding IsEnabled, Converter={StaticResource AvailabilityToCardBackground}}"
                                            Opacity="{Binding IsEnabled, Converter={StaticResource AvailabilityToOpacity}}">
                                        <Grid>
                                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" IsEnabled="{Binding IsEnabled}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                <Border Grid.Column="1" Width="32" Height="32" CornerRadius="6" Background="{Binding IsEnabled, Converter={StaticResource AvailabilityToBadgeBrush}}" VerticalAlignment="Center" Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding BrandInitial}" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{Binding IsEnabled, Converter={StaticResource AvailabilityToTextBrush}}" />
                                                    <TextBlock Text="{Binding Profile}" FontSize="11" FontFamily="Consolas, Microsoft YaHei UI" Foreground="{StaticResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Grid>
                                            <Border Grid.Row="1" Padding="8,3" CornerRadius="10" HorizontalAlignment="Left" Background="{Binding IsCadInstalled, Converter={StaticResource AvailabilityToBadgeBackground}}" Margin="0,8,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{Binding Status, Converter={StaticResource StatusToBrush}}" />
                                                    <TextBlock Text="{Binding StatusText}" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0" />
                                                </StackPanel>
                                            </Border>
                                            <TextBlock Grid.Row="2" FontSize="11" Margin="0,8,0,0" Foreground="{StaticResource SecondaryTextBrush}"><Run Text="已安装版本：" /><Run Text="{Binding InstalledVersion}" /></TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
                <Border Background="{StaticResource CardBrush}" BorderBrush="{StaticResource CardStrokeBrush}" BorderThickness="1" CornerRadius="8">
                    <StackPanel Margin="20">
                        <TextBlock Text="安装目录" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12" />
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding DeployPath, UpdateSourceTrigger=PropertyChanged}" FontFamily="Consolas, Microsoft YaHei UI" Padding="6,4" VerticalContentAlignment="Center" MinHeight="30" />
                            <Button Grid.Column="1" Content="浏览…" Command="{Binding BrowseCommand}" MinWidth="88" Margin="10,0,0,0" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" Text="勾选已安装的版本后，点击安装按钮将 DLL 复制到目录并写入注册表；点击卸载按钮删除 DLL 并清理注册表。" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Content="卸载" Command="{Binding UninstallCommand}" MinWidth="88" Margin="0,0,10,0" />
                                <Button Content="安装" Command="{Binding InstallCommand}" Style="{StaticResource AccentButton}" MinWidth="88" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        <Border Grid.Row="1" BorderThickness="0,1,0,0" BorderBrush="{StaticResource CardStrokeBrush}" Background="#FFFAFAFA" Padding="20,8">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{Binding IsCadRunning, Converter={StaticResource RunningToBrush}}" />
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" FontSize="12" Margin="8,0,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
