<hc:Window x:Class="AFR.Deployer.Views.MainWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:hc="https://handyorg.github.io/handycontrol"
           xmlns:models="clr-namespace:AFR.Deployer.Models"
           Title="AFR 插件统一管理部署工具"
           Icon="/Assets/app.ico"
           Width="900" Height="640"
           MinWidth="740" MinHeight="500"
           WindowStartupLocation="CenterScreen"
           NonClientAreaBackground="{DynamicResource RegionBrush}"
           Background="{DynamicResource RegionBrush}">

    <hc:Window.Resources>
        <!-- 部署状态 → 前景色 -->
        <Style x:Key="StatusCellStyle" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:PluginDeployStatus.InstalledCurrent}">
                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:PluginDeployStatus.InstalledOutdated}">
                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:PluginDeployStatus.DllMissing}">
                    <Setter Property="Foreground" Value="{StaticResource DangerBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="{x:Static models:PluginDeployStatus.NotInstalled}">
                    <Setter Property="Foreground" Value="{StaticResource SubTextBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </hc:Window.Resources>

    <Grid Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 软件信息 -->
            <RowDefinition Height="*"    />  <!-- CAD 列表 -->
            <RowDefinition Height="Auto" />  <!-- 操作区 -->
            <RowDefinition Height="Auto" />  <!-- 状态栏 -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════
             Top Section — 软件信息
             ══════════════════════════════════════════ -->
        <hc:Card Grid.Row="0" Margin="16,12,16,0" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Image Source="/Assets/app.ico" Width="22" Height="22"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="AFR 插件统一管理部署工具"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="12" TextWrapping="Wrap">
                        自动检测本机已安装的 AutoCAD 版本，一键完成插件 DLL 的部署与注册。
                        部署完成后重启对应 CAD，首次进入图纸时运行
                        <Run FontWeight="SemiBold">AFR</Run>
                        命令完成字体配置。
                    </TextBlock>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="↻  刷新"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding RefreshCommand}"
                        VerticalAlignment="Center"
                        Margin="16,0,0,0" />
            </Grid>
        </hc:Card>

        <!-- ══════════════════════════════════════════
             Middle Section — CAD 列表
             ══════════════════════════════════════════ -->
        <hc:Card Grid.Row="1" Margin="16,10,16,0" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*"    />
                </Grid.RowDefinitions>

                <!-- 列표标题行 -->
                <Border Grid.Row="0" Padding="16,10"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="本机已安装的 AutoCAD 版本"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                            <Border Margin="10,0,0,0" Padding="6,2"
                                    CornerRadius="10"
                                    Background="{DynamicResource SecondaryRegionBrush}">
                                <TextBlock Text="{Binding CadEntries.Count, StringFormat={}{0} 个实例}"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           FontSize="11" VerticalAlignment="Center" />
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="全选"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding SelectAllCommand}"
                                    CommandParameter="true"
                                    Height="28" Padding="12,0" FontSize="12" />
                            <Button Content="取消全选"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding SelectAllCommand}"
                                    CommandParameter="false"
                                    Margin="6,0,0,0"
                                    Height="28" Padding="12,0" FontSize="12" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- DataGrid -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding CadEntries}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserReorderColumns="False"
                          CanUserResizeRows="False"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource BorderBrush}"
                          Background="Transparent"
                          RowBackground="Transparent"
                          AlternatingRowBackground="{DynamicResource SecondaryRegionBrush}"
                          BorderThickness="0"
                          RowHeight="38"
                          HeadersVisibility="Column"
                          Style="{StaticResource DataGridBaseStyle}">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader"
                               BasedOn="{StaticResource DataGridColumnHeaderStyle}">
                            <Setter Property="Height"   Value="36" />
                            <Setter Property="Padding"  Value="10,0" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell"
                               BasedOn="{StaticResource DataGridCellStyle}">
                            <Setter Property="Padding" Value="10,0" />
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow"
                               BasedOn="{StaticResource DataGridRowStyle}" />
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>

                        <!-- 勾选框 -->
                        <DataGridTemplateColumn Header="选择" Width="52" CanUserResize="False">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                              HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Style="{StaticResource CheckBoxBaseStyle}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- 品牌 -->
                        <DataGridTextColumn Header="品牌"
                                            Binding="{Binding Brand}"
                                            Width="90" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="Padding"           Value="10,0" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- 版本 -->
                        <DataGridTextColumn Header="版本"
                                            Binding="{Binding Version}"
                                            Width="68" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="Padding"           Value="10,0" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- 配置文件 -->
                        <DataGridTextColumn Header="配置文件"
                                            Binding="{Binding Profile}"
                                            Width="*" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="Padding"           Value="10,0" />
                                    <Setter Property="Foreground"        Value="{DynamicResource SecondaryTextBrush}" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- 已安装版本 -->
                        <DataGridTextColumn Header="已安装版本"
                                            Binding="{Binding InstalledVersion}"
                                            Width="110" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="Padding"           Value="10,0" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- 安装状态 -->
                        <DataGridTemplateColumn Header="状态" Width="160" IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StatusText}"
                                               Style="{StaticResource StatusCellStyle}"
                                               Padding="10,0" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </hc:Card>

        <!-- ══════════════════════════════════════════
             Bottom Section — 路径选择 + 操作按钮
             ══════════════════════════════════════════ -->
        <hc:Card Grid.Row="2" Margin="16,10,16,0" Padding="16,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- 路径选择行 -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*"    />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="安装目录："
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Margin="0,0,8,0" />

                    <hc:TextBox Grid.Column="1"
                                Text="{Binding DeployPath, UpdateSourceTrigger=PropertyChanged}"
                                hc:InfoElement.Placeholder="输入或浏览目标目录…"
                                FontFamily="Consolas, Microsoft YaHei UI"
                                FontSize="12" />

                    <Button Grid.Column="2"
                            Content="浏览…"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding BrowseCommand}"
                            Margin="8,0,0,0"
                            Width="70" />
                </Grid>

                <!-- 操作按钮行 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"    />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="12" TextWrapping="Wrap">
                        勾选列表中的版本，点击"安装"将 DLL 复制到安装目录并写入注册表；
                        点击"卸载"删除 DLL 并清理注册表。
                    </TextBlock>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="卸　载"
                                Style="{StaticResource DangerButtonStyle}"
                                Command="{Binding UninstallCommand}"
                                Width="90" Margin="0,0,8,0" />
                        <Button Content="安　装"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding InstallCommand}"
                                Width="90" />
                    </StackPanel>
                </Grid>
            </Grid>
        </hc:Card>

        <!-- ══════════════════════════════════════════
             StatusBar — 底部状态栏
             ══════════════════════════════════════════ -->
        <Border Grid.Row="3" Margin="16,8,16,12" CornerRadius="6" Padding="14,6">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCadRunning}" Value="True">
                            <Setter Property="Background" Value="{StaticResource WarningBgBrush}" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" FontSize="12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Text"       Value="●" />
                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                            <Setter Property="Margin"     Value="0,0,6,0" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCadRunning}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Text="{Binding StatusText}"
                           VerticalAlignment="Center" FontSize="12">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCadRunning}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource WarningBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>
        </Border>

    </Grid>
</hc:Window>