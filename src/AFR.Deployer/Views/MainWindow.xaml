<ui:FluentWindow x:Class="AFR.Deployer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AFR.Deployer.ViewModels"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AFR 部署工具"
        Width="940" Height="640"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        FontFamily="Microsoft YaHei UI">
    <ui:FluentWindow.Resources>
        <SolidColorBrush x:Key="CardStrokeBrush" Color="#22808080" />
        <SolidColorBrush x:Key="SubtleBrush" Color="#11808080" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#FF666666" />
    </ui:FluentWindow.Resources>
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="AFR 部署工具" ShowMaximize="False" />

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="24,8,24,16">
            <StackPanel>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <ui:TextBlock Text="插件部署" FontTypography="Title" />
                        <ui:TextBlock Text="选中支持的 AutoCAD 版本，一键完成插件 DLL 的部署与注册。未安装的版本将自动禁用。"
                                      Margin="0,4,0,0" Foreground="{StaticResource SecondaryTextBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                    <ui:Button Grid.Column="1" VerticalAlignment="Top"
                               Content="刷新"
                               Icon="{ui:SymbolIcon ArrowClockwise24}"
                               Command="{Binding RefreshCommand}" />
                </Grid>

                <ui:Card Margin="0,0,0,16" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="20,16,20,12">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <ui:TextBlock Text="支持的 AutoCAD 版本" FontTypography="Subtitle" VerticalAlignment="Center" />
                                <Border Background="{StaticResource SubtleBrush}" CornerRadius="10" Padding="8,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock FontSize="11" Foreground="{StaticResource SecondaryTextBrush}"><Run Text="{Binding CadEntries.Count, Mode=OneWay}" /><Run Text=" 项" /></TextBlock>
                                </Border>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ui:HyperlinkButton Content="全选" Command="{Binding SelectAllCommand}" CommandParameter="true" Margin="2,0" />
                                <ui:HyperlinkButton Content="取消全选" Command="{Binding SelectAllCommand}" CommandParameter="false" Margin="2,0" />
                            </StackPanel>
                        </Grid>
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding CadEntries}" Margin="16,0,16,16">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="3" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:CadEntryViewModel}">
                                    <ui:Card Margin="6" Padding="14"
                                             Background="{Binding IsEnabled, Converter={StaticResource AvailabilityToCardBackground}}"
                                             Opacity="{Binding IsEnabled, Converter={StaticResource AvailabilityToOpacity}}">
                                        <Grid>
                                            <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}" IsEnabled="{Binding IsEnabled}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                <Border Grid.Column="1" Width="32" Height="32" CornerRadius="6" Background="{Binding IsEnabled, Converter={StaticResource AvailabilityToBadgeBrush}}" VerticalAlignment="Center" Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding BrandInitial}" Foreground="White" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{Binding IsEnabled, Converter={StaticResource AvailabilityToTextBrush}}" />
                                                    <TextBlock Text="{Binding Profile}" FontSize="11" FontFamily="Consolas, Microsoft YaHei UI" Foreground="{StaticResource SecondaryTextBrush}" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                            </Grid>
                                            <Border Grid.Row="1" Padding="8,3" CornerRadius="10" HorizontalAlignment="Left" Background="{Binding IsCadInstalled, Converter={StaticResource AvailabilityToBadgeBackground}}" Margin="0,8,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{Binding Status, Converter={StaticResource StatusToBrush}}" />
                                                    <TextBlock Text="{Binding StatusText}" FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0" />
                                                </StackPanel>
                                            </Border>
                                            <TextBlock Grid.Row="2" FontSize="11" Margin="0,8,0,0" Foreground="{StaticResource SecondaryTextBrush}"><Run Text="已安装版本：" /><Run Text="{Binding InstalledVersion}" /></TextBlock>
                                        </Grid>
                                    </ui:Card>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </ui:Card>

                <ui:Card Padding="0">
                    <StackPanel Margin="20">
                        <ui:TextBlock Text="安装目录" FontTypography="Subtitle" Margin="0,0,0,12" />
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <ui:TextBox Grid.Column="0"
                                        Text="{Binding DeployPath, UpdateSourceTrigger=PropertyChanged}"
                                        FontFamily="Consolas, Microsoft YaHei UI"
                                        PlaceholderText="部署目录" />
                            <ui:Button Grid.Column="1"
                                       Content="浏览…"
                                       Icon="{ui:SymbolIcon FolderOpen24}"
                                       Command="{Binding BrowseCommand}"
                                       MinWidth="88" Margin="10,0,0,0" />
                        </Grid>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}"
                                       Text="勾选已安装的版本后，点击安装按钮将 DLL 复制到目录并写入注册表；点击卸载按钮删除 DLL 并清理注册表。" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ui:Button Content="卸载"
                                           Icon="{ui:SymbolIcon Delete24}"
                                           Command="{Binding UninstallCommand}"
                                           MinWidth="88" Margin="0,0,10,0" />
                                <ui:Button Content="安装"
                                           Icon="{ui:SymbolIcon ArrowDownload24}"
                                           Appearance="Primary"
                                           Command="{Binding InstallCommand}"
                                           MinWidth="88" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ui:Card>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="{StaticResource CardStrokeBrush}" Padding="20,8">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{Binding IsCadRunning, Converter={StaticResource RunningToBrush}}" />
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" FontSize="12" Margin="8,0,0,0" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
