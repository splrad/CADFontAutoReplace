<ui:FluentWindow x:Class="AFR.Deployer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AFR.Deployer.ViewModels"
        xmlns:models="clr-namespace:AFR.Deployer.Models"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AFR 部署工具"
        Width="760" Height="600"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        FontFamily="Segoe UI, Microsoft YaHei UI">

    <ui:FluentWindow.Resources>
        <!-- 卡片选中态高亮（蓝色描边） -->
        <Style x:Key="CadCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}" />
                    <Setter Property="BorderThickness" Value="2" />
                    <Setter Property="Padding" Value="11,9" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsEnabled}" Value="False">
                    <Setter Property="Opacity" Value="0.55" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题栏：左侧蓝色 AFR 矢量徽标 + 标题 -->
        <ui:TitleBar Grid.Row="0" Title="AFR 部署工具" ShowMaximize="False">
            <ui:TitleBar.Icon>
                <ui:ImageIcon>
                    <ui:ImageIcon.Source>
                        <DrawingImage>
                            <DrawingImage.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="#0F6CBD">
                                        <GeometryDrawing.Geometry>
                                            <RectangleGeometry Rect="0,0,32,32" RadiusX="7" RadiusY="7" />
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                    <GeometryDrawing Brush="White">
                                        <GeometryDrawing.Geometry>
                                            <GeometryGroup>
                                                <!-- 简化的 "AFR" 字样：用矩形拼出 A 形态 -->
                                                <RectangleGeometry Rect="6,9,2.5,14" />
                                                <RectangleGeometry Rect="13,9,2.5,14" />
                                                <RectangleGeometry Rect="6,9,9.5,2.2" />
                                                <RectangleGeometry Rect="6,15,9.5,2.2" />
                                                <RectangleGeometry Rect="19,9,2.5,14" />
                                                <RectangleGeometry Rect="19,9,7,2.2" />
                                                <RectangleGeometry Rect="19,15,7,2.2" />
                                                <RectangleGeometry Rect="23.5,15,2.5,8" />
                                            </GeometryGroup>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingGroup>
                            </DrawingImage.Drawing>
                        </DrawingImage>
                    </ui:ImageIcon.Source>
                </ui:ImageIcon>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" Margin="24,8,24,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 顶部：标题 + 副标题 + 刷新按钮 -->
            <Grid Grid.Row="0" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="插件部署" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="选择版本并安装插件"
                               FontSize="12"
                               Margin="0,2,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <ui:Button Grid.Column="1"
                           VerticalAlignment="Center"
                           Appearance="Secondary"
                           Content="刷新"
                           Icon="{ui:SymbolIcon ArrowClockwise24}"
                           Command="{Binding RefreshCommand}" />
            </Grid>

            <!-- 中部：版本卡片容器 -->
            <Border Grid.Row="1"
                    Background="{DynamicResource LayerFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 容器头：标题 + 全选 + 显示未检测开关 -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="支持的 AutoCAD 版本"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <CheckBox Grid.Column="1"
                                  Content="全选"
                                  Margin="24,0,0,0"
                                  VerticalAlignment="Center"
                                  Click="OnSelectAllClicked" />
                        <TextBlock Grid.Column="3"
                                   Text="显示未检测版本"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ui:ToggleSwitch Grid.Column="4"
                                         IsChecked="{Binding ShowUnavailable, Mode=TwoWay}"
                                         VerticalAlignment="Center" />
                    </Grid>

                    <!-- 卡片网格：WrapPanel + 固定宽度，隐藏卡片不占槽，自动紧凑重排 -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding CadEntries}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:CadEntryViewModel}">
                                <Border Style="{StaticResource CadCardStyle}" Width="126">
                                    <Border.Visibility>
                                        <MultiBinding Converter="{StaticResource InstalledOrShowAllToVisibility}">
                                            <Binding Path="IsCadInstalled" />
                                            <Binding Path="DataContext.ShowUnavailable"
                                                     RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                        </MultiBinding>
                                    </Border.Visibility>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!-- 复选框 -->
                                        <CheckBox Grid.Row="0"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  IsEnabled="{Binding IsEnabled}"
                                                  HorizontalAlignment="Left" />

                                        <!-- 版本名 -->
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding DisplayName}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Margin="0,6,0,0"
                                                   TextTrimming="CharacterEllipsis" />

                                        <!-- 状态点 + 状态文字 -->
                                        <StackPanel Grid.Row="2"
                                                    Orientation="Horizontal"
                                                    Margin="0,4,0,0">
                                            <Ellipse Width="7" Height="7"
                                                     VerticalAlignment="Center"
                                                     Fill="{Binding Status, Converter={StaticResource StatusToBrush}}" />
                                            <TextBlock Text="{Binding StatusText}"
                                                       FontSize="11"
                                                       Margin="6,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>

                                        <!-- 已安装版本号（仅当已部署时） -->
                                        <TextBlock Grid.Row="3"
                                                   Text="{Binding InstalledVersion}"
                                                   FontSize="11"
                                                   FontFamily="Cascadia Mono, Consolas, Microsoft YaHei UI"
                                                   Margin="0,3,0,0"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   Visibility="{Binding CanUninstall, Converter={StaticResource BoolToVisibility}}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- 底部：安装目录 + 操作按钮 -->
            <Border Grid.Row="2"
                    Margin="0,12,0,0"
                    Background="{DynamicResource LayerFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="安装目录"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0"
                                    Text="{Binding DeployPath, UpdateSourceTrigger=PropertyChanged}"
                                    FontFamily="Cascadia Mono, Consolas, Microsoft YaHei UI"
                                    PlaceholderText="部署目录" />
                        <ui:Button Grid.Column="1"
                                   Content="浏览"
                                   Appearance="Secondary"
                                   Icon="{ui:SymbolIcon FolderOpen24}"
                                   Command="{Binding BrowseCommand}"
                                   MinWidth="84"
                                   Margin="10,0,0,0" />
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="插件将部署到所选目录，并完成注册。"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ui:Button Grid.Column="1"
                                   Content="卸载已选版本"
                                   Appearance="Secondary"
                                   Icon="{ui:SymbolIcon Delete24}"
                                   Command="{Binding UninstallCommand}"
                                   MinWidth="120" />
                        <ui:Button Grid.Column="2"
                                   Content="安装选中版本"
                                   Appearance="Primary"
                                   Icon="{ui:SymbolIcon ArrowDownload24}"
                                   Command="{Binding InstallCommand}"
                                   MinWidth="132"
                                   Margin="10,0,0,0" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                Padding="24,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 左：检测计数 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="CheckmarkCircle24"
                                   Foreground="#10884B"
                                   FontSize="16"
                                   VerticalAlignment="Center" />
                    <TextBlock Text="{Binding DetectionSummary}"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Margin="6,0,0,0" />
                </StackPanel>

                <!-- 右：CAD 运行状态 / 操作状态 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Ellipse Width="8" Height="8"
                             VerticalAlignment="Center"
                             Fill="{Binding IsCadRunning, Converter={StaticResource RunningToBrush}}" />
                    <TextBlock Text="{Binding StatusText}"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Margin="8,0,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
