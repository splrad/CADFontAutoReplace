<ui:FluentWindow x:Class="AFR.Deployer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AFR.Deployer.ViewModels"
        xmlns:models="clr-namespace:AFR.Deployer.Models"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AFR 部署工具"
        Width="900" Height="600"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        WindowBackdropType="Mica"
        ExtendsContentIntoTitleBar="True"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        FontFamily="Segoe UI, Microsoft YaHei UI">

    <ui:FluentWindow.Resources>
        <!--
            卡片样式：使用 ToggleButton 实现整卡可点击。
            - 默认态：浅色卡片背景 + 细描边
            - 选中态（已安装）：浅绿底 + 强描边
            - 选中态（未安装/通用）：蓝色强调描边
            - Hover：略加亮
            - Disabled（未检测到 CAD）：保留外观，仅降透明度
        -->
        <Style x:Key="CadCardStyle" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Focusable" Value="True" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
            <!-- 固定边框宽度，选中态仅变颜色，避免内容区出现微位移 -->
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="PART_Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PART_Border" Property="Background"
                                        Value="{DynamicResource CardBackgroundFillColorSecondaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="PART_Border" Property="Background" Value="#E8F7EE" />
                                <Setter TargetName="PART_Border" Property="BorderBrush" Value="#3FAE6A" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!--
            CAD 品牌徽标（矢量原创，参考用户提供的非 Autodesk 模板）：
            - 红色径向渐变圆角底，营造立体光照
            - 高光 / 阴影叠加层提升立体感
            - 中央大写 "A"
            - 底部深色色带 + 年份徽章
        -->
        <Style x:Key="BrandLogoStyle" TargetType="Grid">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="46" />
        </Style>

        <LinearGradientBrush x:Key="BrandLogoBrush" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Offset="0"   Color="#F4B5B5" />
            <GradientStop Offset="0.45" Color="#E26F6F" />
            <GradientStop Offset="1"   Color="#A82323" />
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="BrandLogoHighlight" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Offset="0"    Color="#80FFFFFF" />
            <GradientStop Offset="0.55" Color="#10FFFFFF" />
            <GradientStop Offset="1"    Color="#00FFFFFF" />
        </LinearGradientBrush>

        <SolidColorBrush x:Key="BrandLogoBandBrush" Color="#9A1F1F" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题栏：左侧蓝色 AFR 矢量徽标 + 标题 -->
        <ui:TitleBar Grid.Row="0" Title="AFR 部署工具" ShowMaximize="False">
            <ui:TitleBar.Icon>
                <ui:ImageIcon>
                    <ui:ImageIcon.Source>
                        <DrawingImage>
                            <DrawingImage.Drawing>
                                <DrawingGroup>
                                    <GeometryDrawing Brush="#0F6CBD">
                                        <GeometryDrawing.Geometry>
                                            <RectangleGeometry Rect="0,0,32,32" RadiusX="7" RadiusY="7" />
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                    <GeometryDrawing Brush="White">
                                        <GeometryDrawing.Geometry>
                                            <GeometryGroup>
                                                <!-- 简化的 "AFR" 字样：用矩形拼出 A 形态 -->
                                                <RectangleGeometry Rect="6,9,2.5,14" />
                                                <RectangleGeometry Rect="13,9,2.5,14" />
                                                <RectangleGeometry Rect="6,9,9.5,2.2" />
                                                <RectangleGeometry Rect="6,15,9.5,2.2" />
                                                <RectangleGeometry Rect="19,9,2.5,14" />
                                                <RectangleGeometry Rect="19,9,7,2.2" />
                                                <RectangleGeometry Rect="19,15,7,2.2" />
                                                <RectangleGeometry Rect="23.5,15,2.5,8" />
                                            </GeometryGroup>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingGroup>
                            </DrawingImage.Drawing>
                        </DrawingImage>
                    </ui:ImageIcon.Source>
                </ui:ImageIcon>
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <!-- 主内容区 -->
        <Grid Grid.Row="1" Margin="24,8,24,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 顶部：标题 + 副标题 + 刷新按钮 -->
            <Grid Grid.Row="0" Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="插件部署" FontSize="22" FontWeight="SemiBold" />
                    <TextBlock Text="选择版本并安装插件"
                               FontSize="12"
                               Margin="0,2,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <ui:Button Grid.Column="1"
                           VerticalAlignment="Center"
                           Appearance="Secondary"
                           Content="刷新"
                           Icon="{ui:SymbolIcon ArrowClockwise24}"
                           Command="{Binding RefreshCommand}" />
            </Grid>

            <!-- 中部：版本卡片容器 -->
            <Border Grid.Row="1"
                    Background="{DynamicResource LayerFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 容器头：标题 + 全选 + 显示未检测开关 -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="支持的 AutoCAD 版本"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <CheckBox Grid.Column="1"
                                  Content="全选"
                                  Margin="24,0,0,0"
                                  VerticalAlignment="Center"
                                  Click="OnSelectAllClicked" />
                        <TextBlock Grid.Column="3"
                                   Text="显示未检测版本"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ui:ToggleSwitch Grid.Column="4"
                                         IsChecked="{Binding ShowUnavailable, Mode=TwoWay}"
                                         VerticalAlignment="Center" />
                    </Grid>

                    <!-- 卡片网格：WrapPanel + 固定宽度，隐藏卡片不占槽，自动紧凑重排 -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding CadEntries}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:CadEntryViewModel}">
                                <ToggleButton Style="{StaticResource CadCardStyle}"
                                              Width="196"
                                              IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                              IsEnabled="{Binding IsEnabled}">
                                    <ToggleButton.Visibility>
                                        <MultiBinding Converter="{StaticResource InstalledOrShowAllToVisibility}">
                                            <Binding Path="IsCadInstalled" />
                                            <Binding Path="DataContext.ShowUnavailable"
                                                     RelativeSource="{RelativeSource AncestorType=ItemsControl}" />
                                        </MultiBinding>
                                    </ToggleButton.Visibility>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- 左：矢量品牌徽标（红色渐变圆角底 + 立体 "A" + 底部年份色带） -->
                                        <Grid Grid.Column="0" Style="{StaticResource BrandLogoStyle}"
                                              VerticalAlignment="Center">
                                            <!-- 主体：红色径向渐变 -->
                                            <Border Background="{StaticResource BrandLogoBrush}"
                                                    CornerRadius="9"
                                                    SnapsToDevicePixels="True" />
                                            <!-- 顶部光泽 -->
                                            <Border CornerRadius="9,9,0,0"
                                                    Margin="2,2,2,0"
                                                    Height="20"
                                                    VerticalAlignment="Top"
                                                    Background="{StaticResource BrandLogoHighlight}" />
                                            <!-- 大 "A" -->
                                            <TextBlock Text="A"
                                                       Foreground="#7A0F0F"
                                                       FontWeight="Bold"
                                                       FontSize="30"
                                                       Margin="0,-4,0,6"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Effect>
                                                    <DropShadowEffect Color="#FFFFFF"
                                                                      BlurRadius="2"
                                                                      ShadowDepth="0"
                                                                      Opacity="0.55" />
                                                </TextBlock.Effect>
                                            </TextBlock>
                                            <!-- 底部色带 + 年份徽章 -->
                                            <Border Height="13"
                                                    VerticalAlignment="Bottom"
                                                    CornerRadius="0,0,9,9"
                                                    Background="{StaticResource BrandLogoBandBrush}">
                                                <TextBlock Text="{Binding Version}"
                                                           Foreground="White"
                                                           FontSize="9"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                        </Grid>

                                        <!-- 右：版本名 / 状态 / 已安装版本号 -->
                                        <StackPanel Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Margin="10,0,0,0">
                                            <TextBlock Text="{Binding DisplayName}"
                                                       FontSize="13"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />

                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <Ellipse Width="7" Height="7"
                                                         VerticalAlignment="Center"
                                                         Fill="{Binding Status, Converter={StaticResource StatusToBrush}}" />
                                                <TextBlock Text="{Binding StatusText}"
                                                           FontSize="11"
                                                           Margin="6,0,0,0"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            </StackPanel>

                                            <TextBlock Text="{Binding InstalledVersion}"
                                                       FontSize="11"
                                                       FontFamily="Cascadia Mono, Consolas, Microsoft YaHei UI"
                                                       Margin="0,3,0,0"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       Visibility="{Binding CanUninstall, Converter={StaticResource BoolToVisibility}}" />
                                        </StackPanel>
                                    </Grid>
                                </ToggleButton>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- 底部：安装目录 + 操作按钮 -->
            <Border Grid.Row="2"
                    Margin="0,12,0,0"
                    Background="{DynamicResource LayerFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="14,12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="安装目录"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,8" />

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0"
                                    Text="{Binding DeployPath, UpdateSourceTrigger=PropertyChanged}"
                                    FontFamily="Cascadia Mono, Consolas, Microsoft YaHei UI"
                                    PlaceholderText="部署目录" />
                        <ui:Button Grid.Column="1"
                                   Content="浏览"
                                   Appearance="Secondary"
                                   Icon="{ui:SymbolIcon FolderOpen24}"
                                   Command="{Binding BrowseCommand}"
                                   MinWidth="84"
                                   Margin="10,0,0,0" />
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="插件将部署到所选目录，并完成注册。"
                                   VerticalAlignment="Center"
                                   FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <ui:Button Grid.Column="1"
                                   Content="卸载已选版本"
                                   Appearance="Secondary"
                                   Icon="{ui:SymbolIcon Delete24}"
                                   Command="{Binding UninstallCommand}"
                                   MinWidth="120" />
                        <ui:Button Grid.Column="2"
                                   Content="安装选中版本"
                                   Appearance="Primary"
                                   Icon="{ui:SymbolIcon ArrowDownload24}"
                                   Command="{Binding InstallCommand}"
                                   MinWidth="132"
                                   Margin="10,0,0,0" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- 状态栏 -->
        <Border Grid.Row="2"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                Padding="24,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 左：检测计数 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="CheckmarkCircle24"
                                   Foreground="#10884B"
                                   FontSize="16"
                                   VerticalAlignment="Center" />
                    <TextBlock Text="{Binding DetectionSummary}"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Margin="6,0,0,0" />
                </StackPanel>

                <!-- 右：CAD 运行状态 / 操作状态 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Ellipse Width="8" Height="8"
                             VerticalAlignment="Center"
                             Fill="{Binding IsCadRunning, Converter={StaticResource RunningToBrush}}" />
                    <TextBlock Text="{Binding StatusText}"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Margin="8,0,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
