<Application x:Class="AFR.Deployer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:AFR.Deployer.Converters"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <converters:StatusToBrushConverter x:Key="StatusToBrush" />
            <converters:RunningToBrushConverter x:Key="RunningToBrush" />
            <converters:AvailabilityToOpacityConverter x:Key="AvailabilityToOpacity" />
            <converters:AvailabilityToCardBackgroundConverter x:Key="AvailabilityToCardBackground" />
            <converters:AvailabilityToBadgeBrushConverter x:Key="AvailabilityToBadgeBrush" />
            <converters:AvailabilityToTextBrushConverter x:Key="AvailabilityToTextBrush" />
            <converters:AvailabilityToBadgeBackgroundConverter x:Key="AvailabilityToBadgeBackground" />
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
