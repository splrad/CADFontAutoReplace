{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://afr.local/schemas/dbtext-ai-reviewed-label-v1.json",
  "title": "AFR GlyphCore DBText AI reviewed label v1",
  "type": "object",
  "required": [
    "schema",
    "featureSchema",
    "groupId",
    "labelAction",
    "labelText",
    "context",
    "currentText",
    "candidates"
  ],
  "properties": {
    "schema": {
      "const": "dbtext-ai-reviewed-label-v1"
    },
    "featureSchema": {
      "const": "dbtext-ai-features-v4"
    },
    "groupId": {
      "type": "string",
      "minLength": 1
    },
    "labelAction": {
      "enum": [
        "repair",
        "keep",
        "unsafe",
        "unknown",
        "glyph-issue"
      ]
    },
    "labelText": {
      "type": "string"
    },
    "reviewer": {
      "type": "string"
    },
    "reviewedUtc": {
      "type": "string"
    },
    "batchId": {
      "type": "string"
    },
    "batchRule": {
      "type": "string"
    },
    "batchReviewedSampleIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "batchConfidenceLevel": {
      "type": "string"
    },
    "appliedByGroup": {
      "type": "boolean"
    },
    "appliedByCluster": {
      "type": "boolean"
    },
    "propagationGroupId": {
      "type": "string"
    },
    "propagationClusterId": {
      "type": "string"
    },
    "propagationSignature": {
      "type": "string"
    },
    "clusterReviewedSampleIds": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "clusterRiskSummary": {
      "type": "object"
    },
    "clusterContextSummary": {
      "type": "object"
    },
    "sourceRepresentativeHandle": {
      "type": "string"
    },
    "sourceRepresentativeGroupId": {
      "type": "string"
    },
    "appliedCount": {
      "type": "integer",
      "minimum": 0
    },
    "skippedConflictCount": {
      "type": "integer",
      "minimum": 0
    },
    "skippedRiskCount": {
      "type": "integer",
      "minimum": 0
    },
    "skippedRoundtripCount": {
      "type": "integer",
      "minimum": 0
    },
    "skippedContextCount": {
      "type": "integer",
      "minimum": 0
    },
    "skippedManualCount": {
      "type": "integer",
      "minimum": 0
    },
    "propagationRule": {
      "type": "string"
    },
    "propagationScope": {
      "type": "string"
    },
    "context": {
      "type": "object"
    },
    "currentText": {
      "type": "string"
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "text",
          "source",
          "reason",
          "isRoundTrip",
          "targetScore"
        ],
        "properties": {
          "text": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "isRoundTrip": {
            "type": "boolean"
          },
          "targetScore": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    }
  }
}
