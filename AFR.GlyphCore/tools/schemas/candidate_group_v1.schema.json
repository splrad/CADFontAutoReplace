{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://afr.local/schemas/dbtext-ai-candidate-group-v1.json",
  "title": "AFR GlyphCore DBText AI exported candidate group v1",
  "type": "object",
  "required": [
    "schema",
    "featureSchema",
    "exportId",
    "groupId",
    "drawing",
    "context",
    "geometry",
    "currentText",
    "problemGate",
    "risk",
    "candidates"
  ],
  "properties": {
    "schema": {
      "const": "dbtext-ai-candidate-group-v1"
    },
    "featureSchema": {
      "const": "dbtext-ai-features-v4"
    },
    "exportId": {
      "type": "string",
      "minLength": 1
    },
    "groupId": {
      "type": "string",
      "minLength": 1
    },
    "drawing": {
      "type": "object"
    },
    "context": {
      "type": "object"
    },
    "geometry": {
      "type": "object"
    },
    "currentText": {
      "type": "string"
    },
    "problemGate": {
      "type": "object",
      "required": [
        "hasProblem",
        "reason"
      ],
      "properties": {
        "hasProblem": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "risk": {
      "type": "object"
    },
    "candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "text",
          "source",
          "reason",
          "isRoundTrip",
          "features"
        ],
        "properties": {
          "text": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "isRoundTrip": {
            "type": "boolean"
          },
          "features": {
            "type": "array"
          }
        }
      }
    }
  }
}
