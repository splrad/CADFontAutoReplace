<Window x:Class="AFR_ACAD2026.UI.FontReplacementLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="AFR — 字体替换日志"
        Width="610" Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <SolidColorBrush x:Key="TrueTypeBrush" Color="#7C4DFF"/>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="10" Background="{DynamicResource RegionBrush}"
            MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Grid Margin="20,14,20,14">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 0: 标题 -->
                <RowDefinition Height="8"/>     <!-- 1: 间距 -->
                <RowDefinition Height="Auto"/>  <!-- 2: 状态条 -->
                <RowDefinition Height="8"/>     <!-- 3: 间距 -->
                <RowDefinition Height="*"/>     <!-- 4: 表格区域 -->
                <RowDefinition Height="Auto"/>  <!-- 5: 内联修复区域 -->
                <RowDefinition Height="8"/>     <!-- 6: 间距 -->
                <RowDefinition Height="Auto"/>  <!-- 7: 按钮 -->
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="AFR 字体替换日志"
                           FontSize="16" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Text="可手动调整各样式的替换字体（仅对当前图纸生效）"
                           FontSize="11" Margin="0,3,0,0"
                           Foreground="{DynamicResource SecondaryTextBrush}"/>
            </StackPanel>

            <!-- 状态条：左侧彩色标签 + 右侧统计 -->
            <Border Grid.Row="2" CornerRadius="5" Padding="10,5"
                    Background="{DynamicResource SecondaryRegionBrush}"
                    Visibility="{Binding HasItems, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Right" Text="{Binding SummaryText}"
                               FontSize="11" VerticalAlignment="Center"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- SHX主字体计数 -->
                        <Border CornerRadius="3" Padding="6,2" Margin="0,0,6,0"
                                Background="{DynamicResource PrimaryBrush}"
                                Visibility="{Binding HasShx, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding ShxLabel}" FontSize="10" Foreground="White"/>
                        </Border>
                        <!-- SHX大字体计数 -->
                        <Border CornerRadius="3" Padding="6,2" Margin="0,0,6,0"
                                Background="{DynamicResource WarningBrush}"
                                Visibility="{Binding HasBigFont, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding BigFontLabel}" FontSize="10" Foreground="White"/>
                        </Border>
                        <!-- TrueType 计数 -->
                        <Border CornerRadius="3" Padding="6,2"
                                Background="{StaticResource TrueTypeBrush}"
                                Visibility="{Binding HasTrueType, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding TrueTypeLabel}" FontSize="10" Foreground="White"/>
                        </Border>
                        <!-- 内联修复计数 -->
                        <Border CornerRadius="3" Padding="6,2" Margin="6,0,0,0"
                                Background="{DynamicResource SuccessBrush}"
                                Visibility="{Binding HasInlineFix, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="{Binding InlineFixLabel}" FontSize="10" Foreground="White"/>
                        </Border>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- 表格区域 -->
            <Grid Grid.Row="4">
                <!-- 空状态提示 -->
                <TextBlock Text="当前图纸未检测到缺失字体 ✓"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Visibility="{Binding HasNoItems, Converter={StaticResource BoolToVis}}"/>

                <!-- 数据表格 -->
                <Border CornerRadius="6"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Visibility="{Binding HasItems, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 表头 -->
                        <Border Grid.Row="0" Padding="8,4,24,4"
                                Background="{DynamicResource SecondaryRegionBrush}"
                                CornerRadius="6,6,0,0"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="样式名" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
										   VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="类型" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
										   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="缺失字体" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
										   VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="替换字体" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
										   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- 数据行 -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,1"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3*"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="2*"/>
                                                    <ColumnDefinition Width="2*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding StyleName}"
                                                           FontSize="11" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding StyleName}"/>
                                                <Border Grid.Column="1" CornerRadius="3"
                                                        Padding="4,1" Margin="0,0,4,0"
                                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding FontCategory}" Value="TrueType">
                                                                    <Setter Property="Background" Value="{StaticResource TrueTypeBrush}"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding FontCategory}" Value="SHX大字体">
                                                                    <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <TextBlock Text="{Binding FontCategory}" FontSize="9"
                                                               Foreground="White"/>
                                                </Border>
                                                <TextBlock Grid.Column="2" Text="{Binding MissingFontName}"
                                                           FontSize="11" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource DangerBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding MissingFontName}"/>
                                                <ComboBox Grid.Column="3" IsEditable="True"
                                                          IsTextSearchEnabled="True"
                                                          Height="22" Margin="4,0,2,0"
                                                          hc:InfoElement.Placeholder="选择字体..."
                                                          Style="{StaticResource ComboBoxExtend}"
                                                          ItemsSource="{Binding AvailableFonts}"
                                                          Text="{Binding SelectedReplacement, UpdateSourceTrigger=PropertyChanged}"
                                                          Loaded="OnComboBoxLoaded"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- 内联字体修复区域 -->
            <Border Grid.Row="5" CornerRadius="6" Margin="0,6,0,0"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    Visibility="{Binding HasInlineFix, Converter={StaticResource BoolToVis}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 小标题 -->
                    <Border Grid.Row="0" Padding="8,4" CornerRadius="6,6,0,0"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="MText 内联字体修复（自动完成，无需手动操作）"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </Border>

                    <!-- 内联修复行 -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding InlineFixItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="8,3"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="3*"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="2*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding MissingFont}"
                                                   FontSize="11" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource DangerBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding MissingFont}"/>
                                        <Border Grid.Column="1" CornerRadius="3" Padding="4,1"
                                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                                Background="{DynamicResource SuccessBrush}">
                                            <TextBlock Text="{Binding FixMethod}" FontSize="9" Foreground="White"/>
                                        </Border>
                                        <Border Grid.Column="2" CornerRadius="3" Padding="4,1"
                                                HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding FontCategory}" Value="TrueType">
                                                            <Setter Property="Background" Value="{StaticResource TrueTypeBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding FontCategory}" Value="SHX大字体">
                                                            <Setter Property="Background" Value="{DynamicResource WarningBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding FontCategory}" FontSize="9" Foreground="White"/>
                                        </Border>
                                        <TextBlock Grid.Column="3" Text="{Binding ReplacementFont}"
                                                   FontSize="11" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SuccessBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding ReplacementFont}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- 底部：左侧批量操作 + 右侧按钮 -->
            <DockPanel Grid.Row="7">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="应用替换"
                            MinWidth="80" Height="32" FontSize="12"
                            Margin="0,0,10,0"
                            Style="{StaticResource ButtonPrimary}"
                            hc:BorderElement.CornerRadius="6"
                            IsEnabled="{Binding HasItems}"
                            Click="OnApply"/>
                    <Button Content="关闭"
                            MinWidth="80" Height="32" FontSize="12"
                            hc:BorderElement.CornerRadius="6"
                            Click="OnClose"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding HasItems, Converter={StaticResource BoolToVis}}">
                    <ComboBox Width="110" Height="28" IsEditable="True" IsTextSearchEnabled="True"
                              hc:InfoElement.Placeholder="SHX主字体"
                              Style="{StaticResource ComboBoxExtend}"
                              ItemsSource="{Binding AvailableShxFonts}"
                              Text="{Binding BatchShxFont, UpdateSourceTrigger=PropertyChanged}"
                              Loaded="OnComboBoxLoaded"/>
                    <ComboBox Width="110" Height="28" Margin="4,0,0,0" IsEditable="True" IsTextSearchEnabled="True"
                              hc:InfoElement.Placeholder="SHX大字体"
                              Style="{StaticResource ComboBoxExtend}"
                              ItemsSource="{Binding AvailableShxFonts}"
                              Text="{Binding BatchBigFont, UpdateSourceTrigger=PropertyChanged}"
                              Loaded="OnComboBoxLoaded"/>
                    <ComboBox Width="120" Height="28" Margin="4,0,0,0" IsEditable="True" IsTextSearchEnabled="True"
                              hc:InfoElement.Placeholder="TrueType字体"
                              Style="{StaticResource ComboBoxExtend}"
                              ItemsSource="{Binding AvailableTrueTypeFonts}"
                              Text="{Binding BatchTrueTypeFont, UpdateSourceTrigger=PropertyChanged}"
                              Loaded="OnComboBoxLoaded"/>
                    <Button Content="填充" Height="28" FontSize="11"
                            Margin="5,0,0,0" Padding="6,0"
                            hc:BorderElement.CornerRadius="4"
                            Click="OnBatchApply"/>
                </StackPanel>
            </DockPanel>
        </Grid>
    </Border>
</Window>
