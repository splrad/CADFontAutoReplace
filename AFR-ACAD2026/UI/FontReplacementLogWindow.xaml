<Window x:Class="AFR_ACAD2026.UI.FontReplacementLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="AFR — 字体替换日志"
        Width="700" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="10" Background="{DynamicResource RegionBrush}"
            MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Grid Margin="20,16,20,16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- 0: 标题 -->
                <RowDefinition Height="12"/>    <!-- 1: 间距 -->
                <RowDefinition Height="Auto"/>  <!-- 2: 统计摘要 -->
                <RowDefinition Height="12"/>    <!-- 3: 间距 -->
                <RowDefinition Height="*"/>     <!-- 4: 表格区域 -->
                <RowDefinition Height="12"/>    <!-- 5: 间距 -->
                <RowDefinition Height="Auto"/>  <!-- 6: 按钮 -->
            </Grid.RowDefinitions>

            <!-- 标题 -->
            <StackPanel Grid.Row="0">
                <TextBlock Text="AFR 字体替换日志"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <TextBlock Text="查看缺失字体检测结果，可手动调整各样式的替换字体（仅对当前图纸生效）"
                           FontSize="12" Margin="0,4,0,0"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- 统计摘要 -->
            <Border Grid.Row="2" CornerRadius="6" Padding="12,8"
                    Background="{DynamicResource SecondaryRegionBrush}">
                <TextBlock Text="{Binding SummaryText}" FontSize="12"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           TextWrapping="Wrap"/>
            </Border>

            <!-- 表格区域 -->
            <Grid Grid.Row="4">
                <!-- 空状态提示 -->
                <TextBlock Text="当前图纸未检测到缺失字体 ✓"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           Visibility="{Binding HasNoItems, Converter={StaticResource BoolToVis}}"/>

                <!-- 数据表格 -->
                <Border CornerRadius="6"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Visibility="{Binding HasItems, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 表头（右侧预留滚动条宽度以对齐列） -->
                        <Border Grid.Row="0" Padding="10,7,26,7"
                                Background="{DynamicResource SecondaryRegionBrush}"
                                CornerRadius="6,6,0,0"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="68"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="样式名" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <TextBlock Grid.Column="1" Text="类型" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <TextBlock Grid.Column="2" Text="缺失字体" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                                <TextBlock Grid.Column="3" Text="替换字体" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="4,0,0,0"/>
                            </Grid>
                        </Border>

                        <!-- 数据行 -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,4"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="68"/>
                                                    <ColumnDefinition Width="120"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding StyleName}"
                                                           FontSize="11" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding StyleName}"/>
                                                <Border Grid.Column="1" CornerRadius="3"
                                                        Padding="5,1" Margin="0,0,4,0"
                                                        HorizontalAlignment="Left" VerticalAlignment="Center"
                                                        Background="{DynamicResource PrimaryBrush}">
                                                    <TextBlock Text="{Binding FontCategory}" FontSize="9"
                                                               Foreground="White"/>
                                                </Border>
                                                <TextBlock Grid.Column="2" Text="{Binding MissingFontName}"
                                                           FontSize="11" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource DangerBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding MissingFontName}"/>
                                                <ComboBox Grid.Column="3" IsEditable="True"
                                                          IsTextSearchEnabled="True"
                                                          Height="26" Margin="4,0,4,0"
                                                          hc:InfoElement.Placeholder="选择字体..."
                                                          Style="{StaticResource ComboBoxExtend}"
                                                          ItemsSource="{Binding AvailableFonts}"
                                                          Text="{Binding SelectedReplacement, UpdateSourceTrigger=PropertyChanged}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- 按钮 -->
            <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="应用替换"
                        MinWidth="80" Height="32" FontSize="12"
                        Margin="0,0,10,0"
                        Style="{StaticResource ButtonPrimary}"
                        hc:BorderElement.CornerRadius="6"
                        IsEnabled="{Binding HasItems}"
                        Click="OnApply"/>
                <Button Content="关闭"
                        MinWidth="80" Height="32" FontSize="12"
                        hc:BorderElement.CornerRadius="6"
                        Click="OnClose"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
